---
import Icon from './Icon.astro';
import Magnet from './Magnet.astro';
import GooeyNav from './GooeyNav.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const gooeyItems = [
  { label: 'Home',         href: `${base}/#home`,         section: 'home' },
  { label: 'Work',         href: `${base}/#work`,         section: 'work' },
  { label: 'Projects',     href: `${base}/#projects`,     section: 'projects' },
  { label: 'Education',    href: `${base}/#education`,    section: 'education' },
  { label: 'Achievements', href: `${base}/#achievements`, section: 'achievements' },
  { label: 'Contact',      href: `${base}/#contact`,      section: 'contact' },
  { label: 'Photography',  href: `${base}/#photography` },
];
---

<nav class="fixed top-0 w-full z-50 glass-nav">
  <div class="nav-inner max-w-7xl mx-auto flex justify-between items-center px-6 md:px-12 py-5">

    <a href={`${base}/`} aria-label="Home">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 80" width="56" height="22" aria-hidden="true">
        <path fill="#E8A444" d="M0,80 L0,62 L18,55 L30,48 L45,40 L55,32 L65,20 L72,10 L78,4 L83,10 L88,18 L94,28 L100,36 L108,26 L114,18 L120,22 L126,30 L132,38 L140,44 L150,50 L162,46 L170,38 L176,42 L182,50 L190,56 L200,60 L200,80 Z"/>
      </svg>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center">
      <GooeyNav items={gooeyItems} particleCount={12} animationTime={500} />
    </div>

    <div class="flex items-center gap-3">
      <Magnet padding={36} magnetStrength={6} maxDisplacement={4} class="hidden md:inline-flex">
        <a href="https://github.com/singhkritesh" target="_blank" rel="noopener noreferrer"
           class="github-btn inline-flex items-center justify-center w-9 h-9 rounded-lg border border-neutral-300
                  text-neutral-500">
          <Icon name="github" size={16} />
        </a>
      </Magnet>
      <Magnet padding={36} magnetStrength={6} maxDisplacement={4}>
        <a
          href={`${base}/Resume/Resume_Kritesh_Singh.pdf`}
          target="_blank"
          rel="noopener noreferrer"
          class="resume-btn inline-flex items-center gap-1.5 px-5 py-2 bg-primary text-[#131313]
                 rounded-lg font-headline text-xs font-bold uppercase tracking-wider"
        >
          <Icon name="download" size={15} />
          Resume
        </a>
      </Magnet>

      <!-- Hamburger (mobile only) -->
      <button id="mobile-menu-btn"
              class="md:hidden flex flex-col items-center justify-center gap-[5px] w-11 h-11 flex-shrink-0"
              aria-label="Toggle menu" aria-expanded="false">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>

  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="mobile-menu md:hidden">
    <div class="mobile-menu-inner">
      <div class="px-6 pb-6 pt-2 flex flex-col gap-1 border-t border-black/[0.06]">
        <a href={`${base}/#home`}         class="mobile-nav-link" data-section="home">Home</a>
        <a href={`${base}/#work`}         class="mobile-nav-link" data-section="work">Work</a>
        <a href={`${base}/#projects`}     class="mobile-nav-link" data-section="projects">Projects</a>
        <a href={`${base}/#education`}    class="mobile-nav-link" data-section="education">Education</a>
        <a href={`${base}/#achievements`} class="mobile-nav-link" data-section="achievements">Achievements</a>
        {/* <a href={`${base}/#blog`} class="mobile-nav-link" data-section="blog">Blog</a> */}
        <a href={`${base}/#contact`}      class="mobile-nav-link" data-section="contact">Contact</a>
        <a href={`${base}/#photography`}
           class="mobile-nav-link inline-flex items-center gap-1.5">
          <Icon name="photo_camera" size={14} />
          Photography
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  // ── Section tracker (excludes hidden photography when not shown) ──
  function currentSectionId(): string {
    const showingPhoto = document.body.classList.contains('show-photography');
    const allSections = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));
    const visible = allSections.filter(s =>
      s.id === 'photography' ? showingPhoto : !showingPhoto
    );
    if (visible.length === 0) return '';
    const threshold = window.innerHeight * 0.4;
    let current = visible[0];
    for (const s of visible) {
      if (s.getBoundingClientRect().top < threshold) current = s;
      else break;
    }
    return current.id;
  }

  // ── Photography show/hide ──────────────────────────────────
  function showPhotography() {
    document.body.classList.add('show-photography');
    sessionStorage.setItem('_sk', 'photography');
    window.scrollTo(0, 0);
    document.dispatchEvent(new CustomEvent('photography:show'));
    // Nudge data-reveal elements in photography section in case IO already fired
    document.querySelectorAll<HTMLElement>('#photography [data-reveal]').forEach(el => {
      el.classList.add('revealed');
    });
  }

  function hidePhotography() {
    document.body.classList.remove('show-photography');
  }

  // ── Hover prefetch: warm browser cache before click ────────
  let prefetched = false;
  function prefetchPhotos() {
    if (prefetched) return;
    prefetched = true;
    document.querySelectorAll<HTMLElement>('#photography .masonry-img').forEach(el => {
      const bg = el.style.backgroundImage;
      const src = bg.replace(/^url\(['"]?/, '').replace(/['"]?\)$/, '');
      if (src) { const img = new Image(); img.src = src; }
    });
  }

  document.querySelectorAll<HTMLElement>('a[href$="#photography"], a[href*="/#photography"]').forEach(a => {
    a.addEventListener('mouseenter', prefetchPhotos, { once: true });
  });

  // ── Shrink nav on scroll ───────────────────────────────────
  const nav = document.querySelector<HTMLElement>('nav')!;
  function updateScrolled() {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  }
  window.addEventListener('scroll', updateScrolled, { passive: true });
  updateScrolled();

  // ── Persist current section for scroll restoration ─────────
  let saveTimer: number;
  window.addEventListener('scroll', () => {
    if (document.body.classList.contains('show-photography')) return;
    clearTimeout(saveTimer);
    saveTimer = window.setTimeout(() => {
      const id = currentSectionId();
      if (id) sessionStorage.setItem('_sk', id);
    }, 150);
  }, { passive: true });

  // ── Smooth scroll / photography toggle ────────────────────
  document.querySelectorAll<HTMLAnchorElement>('a[href*="#"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      const href = a.getAttribute('href')!;
      const hashIdx = href.indexOf('#');
      if (hashIdx === -1) return;
      const id = href.substring(hashIdx + 1);
      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      closeMobileMenu();

      if (id === 'photography') {
        showPhotography();
        return;
      }

      if (document.body.classList.contains('show-photography')) {
        hidePhotography();
      }

      sessionStorage.setItem('_sk', id);
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // ── Mobile menu ────────────────────────────────────────────
  const btn  = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;

  function openMobileMenu() {
    menu.classList.add('open');
    btn.classList.add('open');
    btn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    menu.classList.remove('open');
    btn.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  btn.addEventListener('click', () => {
    menu.classList.contains('open') ? closeMobileMenu() : openMobileMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu.classList.contains('open')) closeMobileMenu();
  });

  document.addEventListener('click', (e) => {
    const nav = document.querySelector('nav')!;
    if (!nav.contains(e.target as Node)) closeMobileMenu();
  });
</script>
