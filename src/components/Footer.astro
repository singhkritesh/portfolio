---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="bg-surface-low border-t border-white/5 py-10 px-6 md:px-12">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
    <div class="font-headline font-bold text-white text-lg tracking-tighter">Kritesh Singh</div>
    <p class="font-body text-[10px] uppercase tracking-widest text-neutral-500">
      © 2025 · All rights reserved
    </p>
    <div class="flex gap-6">
      <a href="https://www.linkedin.com/in/singhkritesh/"
         target="_blank" rel="noopener noreferrer"
         class="text-neutral-400 hover:text-primary transition-colors text-xs font-headline uppercase tracking-wider">
        LinkedIn
      </a>
      <a href="https://github.com/singhkritesh"
         target="_blank" rel="noopener noreferrer"
         class="text-neutral-400 hover:text-primary transition-colors text-xs font-headline uppercase tracking-wider">
        GitHub
      </a>
      <a href={`${base}/Resume/Resume_Kritesh_Singh.pdf`}
         target="_blank" rel="noopener noreferrer"
         class="text-neutral-400 hover:text-primary transition-colors text-xs font-headline uppercase tracking-wider">
        Resume
      </a>
    </div>
  </div>
</footer>
