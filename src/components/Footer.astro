---
import Magnet from './Magnet.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="bg-surface-low border-t border-black/[0.06] py-10 px-6 md:px-12">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
    <div class="font-headline font-bold text-[#131313] text-lg tracking-tighter">Kritesh Singh</div>
    <p class="font-body text-[10px] uppercase tracking-widest text-neutral-500">
      © 2026 · All rights reserved
    </p>
    <div class="flex gap-6">
      <Magnet padding={32} magnetStrength={5} maxDisplacement={7}>
        <a href="https://www.linkedin.com/in/singhkritesh/"
           target="_blank" rel="noopener noreferrer"
           class="text-neutral-500 hover:text-primary transition-colors text-xs font-headline uppercase tracking-wider">
          LinkedIn
        </a>
      </Magnet>
      <Magnet padding={32} magnetStrength={5} maxDisplacement={7}>
        <a href="https://github.com/singhkritesh"
           target="_blank" rel="noopener noreferrer"
           class="text-neutral-500 hover:text-primary transition-colors text-xs font-headline uppercase tracking-wider">
          GitHub
        </a>
      </Magnet>
      <Magnet padding={32} magnetStrength={5} maxDisplacement={7}>
        <a href={`${base}/Resume/Resume_Kritesh_Singh.pdf`}
           target="_blank" rel="noopener noreferrer"
           class="text-neutral-500 hover:text-primary transition-colors text-xs font-headline uppercase tracking-wider">
          Resume
        </a>
      </Magnet>
    </div>
  </div>
</footer>
