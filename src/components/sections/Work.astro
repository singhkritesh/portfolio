---
import { Image } from 'astro:assets';
import careHealthImg from '../../assets/images/care-health.png';
import parsaImg     from '../../assets/images/parsa.png';
import dnpwcImg     from '../../assets/images/dnpwc.png';
---

<section id="work" class="pt-10 pb-32 px-6 md:px-12 bg-background">
  <div class="max-w-7xl mx-auto">

    <div class="mb-10" data-reveal>
      <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter">
        Professional Experience
      </h2>
    </div>

    <!-- Two-column: company decks + role detail -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12">

      <!-- Left: company deck tabs -->
      <div class="lg:col-span-3">
        <div class="lg:sticky lg:top-28 space-y-3 work-tablist" role="tablist" aria-label="Work experience">

          <!-- Care Health -->
          <button id="tab-care-health" class="work-tab active w-full text-left" data-tab="care-health"
                  role="tab" aria-selected="true" aria-controls="panel-care-health">
            <div class="flex items-center gap-5">
              <div class="w-14 h-14 flex items-center justify-center flex-shrink-0 overflow-hidden">
                <Image src={careHealthImg} alt="Care Health" width={224} height={224} class="w-full h-full object-contain" />
              </div>
              <div class="min-w-0">
                <p class="font-headline text-base font-semibold text-[#131313]">Care Health Insurance</p>
                <p class="font-body text-xs text-neutral-500 mt-0.5">Jun 2021 – Aug 2025</p>
              </div>
            </div>
          </button>

          <!-- Parsa National Park -->
          <button id="tab-parsa" class="work-tab w-full text-left" data-tab="parsa"
                  role="tab" aria-selected="false" aria-controls="panel-parsa">
            <div class="flex items-center gap-5">
              <div class="w-14 h-14 flex items-center justify-center flex-shrink-0 overflow-hidden">
                <Image src={parsaImg} alt="Parsa" width={224} height={224} class="w-full h-full object-contain" />
              </div>
              <div class="min-w-0">
                <p class="font-headline text-base font-semibold text-neutral-500">Parsa National Park</p>
                <p class="font-body text-xs text-neutral-500 mt-0.5">Nov 2023 – Oct 2024</p>
              </div>
            </div>
          </button>

        </div>
      </div>

      <!-- Right: role detail panels -->
      <div class="lg:col-span-9">

        <!-- Care Health panel: two roles stacked -->
        <div class="role-panel active" data-role="care-health" id="panel-care-health" role="tabpanel" aria-labelledby="tab-care-health">

          <!-- Role 1: PM AI Strategy (most recent) -->
          <div class="mb-5" data-panel-item="0" data-stagger data-stagger-delay="160">
            <div class="flex flex-wrap justify-between items-baseline gap-x-4 gap-y-0.5 mb-1">
              <h3 class="font-headline text-xl md:text-2xl font-bold">Product Manager — AI Strategy</h3>
              <span class="text-neutral-600 font-body text-xs tracking-wide whitespace-nowrap">Apr 2023 – Aug 2025</span>
            </div>
            <p class="text-neutral-500 text-sm font-body">Care Health Insurance Ltd · India</p>
          </div>
          <div class="bg-surface-mid p-6 rounded-xl border border-outline-dim mb-8" data-panel-item="1" data-stagger data-stagger-delay="260">
            <ul class="space-y-4">
              <li class="flex gap-3 border-l-2 border-primary/40 pl-3">
                <span class="text-sm text-neutral-700">Architected and executed the strategic roadmap for an AI portfolio of <strong class="text-primary">6 products across 7 business functions</strong>, managing <strong class="text-primary">3 PMs</strong> and aligning <strong class="text-primary">17 cross-functional teams</strong> on long-term OKRs spanning fraud, document intelligence, medical data, KYC, and CRM</span>
              </li>
              <li class="flex gap-3 border-l-2 border-primary/40 pl-3">
                <span class="text-sm text-neutral-700">Launched a 0-to-1 AI-native claims automation platform — owned roadmap, model selection, and human-in-the-loop rollout — scaled to <strong class="text-primary">1.9M+ claims (+12% YoY)</strong>, cut processing <strong class="text-primary">20%</strong>, saved <strong class="text-primary">$1.1M+</strong>, and enabled fraud detection (Best Innovation Award, AWS AI Impact 2026)</span>
              </li>
              <li class="flex gap-3 border-l-2 border-primary/40 pl-3">
                <span class="text-sm text-neutral-700">Built KYC Automation in-house after <strong class="text-primary">11 discovery interviews</strong> with a team of 4, saving <strong class="text-primary">$400K</strong>; classifies, masks, and extracts KYC documents at <strong class="text-primary">96% accuracy</strong> with government registry validation</span>
              </li>
              <li class="flex gap-3 border-l-2 border-primary/40 pl-3">
                <span class="text-sm text-neutral-700">Built the company's first AI eval function, shifting a <strong class="text-primary">5-person QA team</strong> to a hybrid eval model and cutting production issues <strong class="text-primary">17%</strong></span>
              </li>
              <li class="flex gap-3 border-l-2 border-primary/40 pl-3">
                <span class="text-sm text-neutral-700">Designed context and prompt engineering pipeline (multi-stage extraction, JSON-stitching) that cut user QC time <strong class="text-primary">35%</strong>, enabled <strong class="text-primary">14% straight-through</strong> claims, and raised extraction accuracy to <strong class="text-primary">76% per document / 94% per field</strong></span>
              </li>
              <li class="flex gap-3 border-l-2 border-primary/40 pl-3">
                <span class="text-sm text-neutral-700">Presented monthly and quarterly AI strategy reviews to executives, securing <strong class="text-primary">7 hires</strong> and <strong class="text-primary">$600K+</strong> in budget, and expanding the AI portfolio into new business domains</span>
              </li>
            </ul>
          </div>

          <!-- Divider with progression indicator -->
          <div class="flex items-center gap-3 mb-8" data-panel-item="2" data-stagger data-stagger-delay="400">
            <div class="h-px flex-1 bg-outline-dim"></div>
            <span class="text-[10px] font-headline uppercase tracking-widest text-neutral-500 px-2">Promoted</span>
            <div class="h-px flex-1 bg-outline-dim"></div>
          </div>

          <!-- Role 2: APM Claims -->
          <div class="mb-5" data-panel-item="3" data-stagger data-stagger-delay="500">
            <div class="flex flex-wrap justify-between items-baseline gap-x-4 gap-y-0.5 mb-1">
              <h3 class="font-headline text-xl md:text-2xl font-bold">Associate Product Manager — Claims</h3>
              <span class="text-neutral-600 font-body text-xs tracking-wide whitespace-nowrap">Jun 2021 – Mar 2023</span>
            </div>
            <p class="text-neutral-500 text-sm font-body">Care Health Insurance Ltd · India</p>
          </div>
          <div class="bg-surface-mid p-6 rounded-xl border border-outline-dim" data-panel-item="4" data-stagger data-stagger-delay="600">
            <ul class="space-y-4">
              <li class="flex gap-3 border-l-2 border-primary/40 pl-3">
                <span class="text-sm text-neutral-700">Led mobile app GTM and redesign — conducted <strong class="text-primary">40 customer interviews</strong> and analyzed <strong class="text-primary">200+ support tickets</strong> to uncover core pain points — growing daily adoption <strong class="text-primary">125% (400 → 900+ cases)</strong></span>
              </li>
              <li class="flex gap-3 border-l-2 border-primary/40 pl-3">
                <span class="text-sm text-neutral-700">Designed the payment engine that became the company standard for all payouts (customers, agents, brokers), cutting payout time from <strong class="text-primary">2 days to 5 secs</strong> across <strong class="text-primary">$15M+</strong> in disbursements</span>
              </li>
              <li class="flex gap-3 border-l-2 border-primary/40 pl-3">
                <span class="text-sm text-neutral-700">Scaled the digital ecosystem by integrating <strong class="text-primary">96+ APIs</strong> across partner and hospital networks, cutting claims processing time by <strong class="text-primary">75%</strong> and lifting digital engagement by <strong class="text-primary">18%</strong></span>
              </li>
            </ul>
          </div>

        </div>

        <!-- Parsa panel -->
        <div class="role-panel" data-role="parsa" id="panel-parsa" role="tabpanel" aria-labelledby="tab-parsa" style="display:none">
          <div class="flex flex-wrap justify-between items-baseline gap-x-4 gap-y-0.5 mb-1" data-panel-item="0">
            <h3 class="font-headline text-xl md:text-2xl font-bold">Volunteer — Conservation</h3>
            <span class="text-neutral-600 font-body text-xs tracking-wide whitespace-nowrap">Nov–Dec '23 · Sep–Oct '24</span>
          </div>
          <p class="text-neutral-500 text-sm font-body mb-5" data-panel-item="1">Parsa National Park · Nepal</p>
          <div class="flex items-center gap-3 mb-5" data-panel-item="2">
            <div class="w-9 h-9 flex items-center justify-center flex-shrink-0 overflow-hidden">
              <Image src={parsaImg} alt="Parsa" width={144} height={144} class="w-full h-full object-contain" />
            </div>
            <div class="w-9 h-9 flex items-center justify-center flex-shrink-0 overflow-hidden">
              <Image src={dnpwcImg} alt="DNPWC" width={144} height={144} class="w-full h-full object-contain" />
            </div>
          </div>
          <div class="bg-surface-mid p-6 rounded-xl border border-outline-dim" data-panel-item="3">
            <ul class="space-y-4">
              <li class="flex gap-3 border-l-2 border-primary/40 pl-3">
                <span class="text-sm text-neutral-700">Volunteered alongside conservationists to raise awareness about nature conservation to local communities in buffer zone areas surrounding the park, contributing to strategies that reduce human-animal conflict.</span>
              </li>
            </ul>
          </div>
        </div>

      </div>
    </div>

    <!-- Full-width skills strip -->
    <div class="bg-surface-mid p-8 rounded-xl border border-outline-dim" data-stagger data-stagger-delay="700">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <p class="section-label mb-4">Product Management</p>
          <div class="flex flex-wrap gap-2">
            {['PRD','Product Roadmaps','Go-to-Market (GTM)','Platform Strategy',
              'Customer Journey Mapping','Backlog Prioritization','A/B Testing',
              'Success Metrics (OKRs, NPS, Engagement)','Figma','Lovable'].map(s => (
              <span class="px-2.5 py-1 bg-surface-high text-neutral-600 rounded-full text-[11px]">{s}</span>
            ))}
          </div>
        </div>
        <div class="md:border-l md:border-outline-dim md:pl-8">
          <p class="section-label mb-4">Technical</p>
          <div class="flex flex-wrap gap-2">
            {['AWS (Bedrock, ECS, Lambda, Textract, Sagemaker, SQS, SNS)','PostgreSQL',
              'API Integration','Generative AI (GenAI)','OCR','Python','Docker',
              'Google Antigravity','LLM Evaluation','RAG','Claude Code','OpenAI Codex'].map(s => (
              <span class="px-2.5 py-1 bg-primary/10 border border-primary/15 text-primary/80 rounded-full text-[11px]">{s}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  // ── Section-level stagger reveal ─────────────────────────────
  // Watches the #work section. When it enters view, each [data-stagger]
  // child reveals after its own explicit data-stagger-delay (ms).
  // Fires once only — observer disconnects on first trigger.
  (function () {
    const section = document.getElementById('work');
    if (!section) return;

    const items = Array.from(
      section.querySelectorAll<HTMLElement>('[data-stagger]')
    );

    // If the section is already in the viewport on page load (e.g. session restore
    // scrolled here before JS ran), skip the animation and force elements visible.
    // Inline opacity overrides the CSS [data-stagger]{opacity:0} and is not
    // blocked by the .preload animation suppression.
    if (section.getBoundingClientRect().top < window.innerHeight * 0.9) {
      items.forEach((el) => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      return;
    }

    let fired = false;

    const obs = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting || fired) return;
        fired = true;
        obs.disconnect();

        items.forEach((el) => {
          const delay = parseInt(el.dataset.staggerDelay ?? '0', 10);
          setTimeout(() => el.classList.add('in'), delay);
        });
      },
      { threshold: 0.08 }
    );

    obs.observe(section);
  })();

  // ── Tab navigation ────────────────────────────────────────────
  const tabs   = Array.from(document.querySelectorAll<HTMLButtonElement>('.work-tab'));
  const panels = Array.from(document.querySelectorAll<HTMLDivElement>('.role-panel'));

  let isAnimating = false;

  function setTabStates(activeTab: HTMLButtonElement) {
    tabs.forEach((t) => {
      t.classList.toggle('active', t === activeTab);
      t.setAttribute('aria-selected', String(t === activeTab));
    });
  }

  function enterPanel(panel: HTMLDivElement) {
    // Strip stagger .in so itemReveal animation takes over cleanly
    panel.querySelectorAll('[data-panel-item]').forEach(el => el.classList.remove('in'));
    panel.style.display = '';
    panel.classList.add('active', 'role-panel--entering');
    // Unlock after panel itself has entered (380ms)
    setTimeout(() => { isAnimating = false; }, 380);
    // Remove entering class after all staggered items finish (last item: 310+450=760ms)
    // Then lock items visible so they don't fall back to [data-stagger]{opacity:0}
    setTimeout(() => {
      panel.classList.remove('role-panel--entering');
      panel.querySelectorAll<HTMLElement>('[data-panel-item]').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }, 1100);
    const section = document.getElementById('work')!;
    if (section.getBoundingClientRect().top < 80) {
      window.scrollTo({ top: Math.max(0, section.offsetTop - 80), behavior: 'instant' });
    }
  }

  function activateTab(tab: HTMLButtonElement, animate = true) {
    if (isAnimating) return;
    const target       = tab.dataset.tab;
    const currentPanel = panels.find(p => p.classList.contains('active'));
    const nextPanel    = panels.find(p => p.dataset.role === target);

    if (!nextPanel || currentPanel === nextPanel) return;

    setTabStates(tab);

    if (!animate || !currentPanel) {
      panels.forEach(p => { p.classList.remove('active'); p.style.display = 'none'; });
      enterPanel(nextPanel);
      return;
    }

    isAnimating = true;
    currentPanel.classList.add('role-panel--exiting');

    setTimeout(() => {
      currentPanel.classList.remove('active', 'role-panel--exiting');
      currentPanel.style.display = 'none';
      enterPanel(nextPanel);
    }, 180); // matches panelExit duration
  }

  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => activateTab(tab));

    tab.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        e.preventDefault();
        const next = tabs[(i + 1) % tabs.length];
        next.focus();
        activateTab(next);
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        e.preventDefault();
        const prev = tabs[(i - 1 + tabs.length) % tabs.length];
        prev.focus();
        activateTab(prev);
      }
    });
  });
</script>
