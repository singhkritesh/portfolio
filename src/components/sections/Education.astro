---
import { Image } from 'astro:assets';
import dartmouthImg  from '../../assets/images/dartmouthlogo.png';
import mnnitImg      from '../../assets/images/mnnitlogo.png';
import googleImg     from '../../assets/images/google.png';
import microsoftImg  from '../../assets/images/microsoft.png';
---

<section id="education" class="pt-20 pb-32 px-6 md:px-12 bg-background">
  <div class="max-w-7xl mx-auto">

    <div class="mb-20" data-reveal>
      <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter">
        Academic Background
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">

      <!-- Dartmouth -->
      <div class="bg-surface-mid p-8 rounded-xl border border-outline-dim" data-reveal data-reveal-delay="50">
        <div class="flex items-center gap-4 mb-6">
          <Image src={dartmouthImg} alt="Dartmouth" width={192} height={192}
                 class="h-12 w-12 object-contain flex-shrink-0" />
          <div>
            <h3 class="font-headline text-xl font-bold">Dartmouth College</h3>
            <p class="text-neutral-500 text-[10px] font-body uppercase tracking-wider mt-1">
              Thayer School of Engineering & Tuck School of Business
            </p>
          </div>
        </div>
        <h4 class="font-headline text-sm font-semibold text-neutral-800 mb-3">
          Master of Engineering Management (MEM)
        </h4>
        <div class="flex items-center gap-2 mb-4 pl-1 border-l-2 border-primary/40">
          <p class="text-xs text-neutral-600">Thayer Scholarship Recipient</p>
        </div>
        <p class="font-body text-xs text-neutral-500 uppercase tracking-wider mb-3">Relevant Coursework</p>
        <div class="grid grid-cols-2 gap-x-4 gap-y-1.5 mb-6">
          {['Technology Assessment','Machine Learning','Marketing','Statistics','Operations Management','Pricing Strategy','Data Analytics','Accounting and Finance','International Strategy','Negotiations'].map(c => (
            <div class="flex gap-2 text-sm text-neutral-600"><span class="text-primary">·</span> {c}</div>
          ))}
        </div>
        <p class="font-body text-xs text-neutral-500 uppercase tracking-wider mb-3">Activities</p>
        <div class="space-y-5">
          <div>
            <p class="text-sm font-medium text-neutral-800 mb-1.5">President — Product Management Club</p>
            <p class="text-sm text-neutral-600 leading-relaxed">Leading the PM Club at Dartmouth, organising events, speaker sessions, and building a community for students interested in product management across Tuck and Thayer.</p>
          </div>
          <div>
            <p class="text-sm font-medium text-neutral-800 mb-1.5">Graduate Student Representative — Thayer Student Council</p>
            <p class="text-sm text-neutral-600 leading-relaxed">Representing graduate students in school-wide council discussions, advocating for student interests on academic and campus policy matters.</p>
          </div>
        </div>
      </div>

      <!-- MNNIT -->
      <div class="bg-surface-mid p-8 rounded-xl border border-outline-dim" data-reveal data-reveal-delay="120">
        <div class="flex items-center gap-4 mb-6">
          <Image src={mnnitImg} alt="MNNIT" width={192} height={192}
                 class="h-12 w-12 object-contain flex-shrink-0" />
          <div>
            <h3 class="font-headline text-xl font-bold">Motilal Nehru National Institute of Technology</h3>
          </div>
        </div>
        <h4 class="font-headline text-sm font-semibold text-neutral-800 mb-3">
          B.Tech — Electronics & Communications Engineering
        </h4>
        <div class="flex items-center gap-2 mb-4 pl-1 border-l-2 border-primary/40">
          <p class="text-xs text-neutral-600">Full scholarship awarded by the Government of India · Merit-based, 1% grant rate from 10,000 applicants</p>
        </div>
        <p class="font-body text-xs text-neutral-500 uppercase tracking-wider mb-3">Relevant Coursework</p>
        <ul class="space-y-1.5 text-sm text-neutral-600 mb-6">
          {['Data Structures & Operating Systems','Numerical Methods & Statistical Techniques','Mathematics I, II, III','Principles of Management'].map(c => (
            <li class="flex gap-2 text-neutral-600"><span class="text-primary">·</span> {c}</li>
          ))}
        </ul>
        <p class="font-body text-xs text-neutral-500 uppercase tracking-wider mb-3">Activities</p>
        <div class="space-y-5">
          <div>
            <p class="text-sm font-medium text-neutral-800 mb-1.5">Co-President — Media House of MNNIT</p>
            <p class="text-sm text-neutral-600 leading-relaxed">Led media coverage and digital promotions for 5 major institute events including Avishkar (National Technical Festival), VCAS (International Conference), Renaissance, Eloquence, and Culrav.</p>
          </div>
          <div>
            <p class="text-sm font-medium text-neutral-800 mb-1.5">Mentor — Student Mentorship Program</p>
            <p class="text-sm text-neutral-600 leading-relaxed">Guided junior students on academics, career planning, and campus life through regular one-on-ones, helping them set and pursue short- and long-term goals.</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Certifications -->
    <div>
      <p class="section-label mb-6" data-reveal data-reveal-delay="50">Certifications</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <a href="https://www.coursera.org/account/accomplishments/specialization/KCW4VLSU6TPY"
           target="_blank" rel="noopener noreferrer"
           class="bg-surface-mid p-6 rounded-xl border border-outline-dim bento-card flex gap-5 items-start group"
           data-tilt data-reveal data-reveal-delay="80">
          <Image src={googleImg} alt="Google" width={192} height={192}
                 class="h-12 w-12 flex-shrink-0 object-contain" />
          <div>
            <h4 class="font-headline text-base font-bold mb-1 group-hover:text-primary transition-colors">Google GenAI Specialisation</h4>
            <p class="text-neutral-500 text-xs uppercase tracking-wider mb-2">Google</p>
            <p class="text-neutral-600 text-sm leading-relaxed">
              Foundational and applied concepts in large language models, prompt engineering,
              and responsible AI development.
            </p>
          </div>
        </a>

        <a href="https://www.coursera.org/account/accomplishments/specialization/O089QDOBZA29"
           target="_blank" rel="noopener noreferrer"
           class="bg-surface-mid p-6 rounded-xl border border-outline-dim bento-card flex gap-5 items-start group"
           data-tilt data-reveal data-reveal-delay="150">
          <Image src={microsoftImg} alt="Microsoft" width={192} height={192}
                 class="h-12 w-12 flex-shrink-0 object-contain" />
          <div>
            <h4 class="font-headline text-base font-bold mb-1 group-hover:text-primary transition-colors">AI Product Manager</h4>
            <p class="text-neutral-500 text-xs uppercase tracking-wider mb-2">Microsoft</p>
            <p class="text-neutral-600 text-sm leading-relaxed">
              Integrating AI capabilities into product strategy, roadmap planning, and
              cross-functional execution.
            </p>
          </div>
        </a>

      </div>
    </div>
  </div>
</section>
