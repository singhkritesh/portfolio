---
import Icon from '../Icon.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const socials = [
  { href: 'https://www.linkedin.com/in/singhkritesh/', icon: 'fa-brands fa-linkedin', label: 'LinkedIn' },
  { href: 'https://github.com/singhkritesh', icon: 'fa-brands fa-github', label: 'GitHub' },
  { href: 'https://discord.com/users/573887153969430528', icon: 'fa-brands fa-discord', label: 'Discord' },
  { href: 'https://www.instagram.com/_kritesh_singh_', icon: 'fa-brands fa-instagram', label: 'Instagram' },
];
---

<section id="contact" class="pt-20 pb-32 px-6 md:px-12 bg-background">
  <div class="max-w-3xl mx-auto">

    <div class="mb-16">
      <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter mb-6">Let's Talk.</h2>
      <p class="text-neutral-400 text-base leading-relaxed">
        Open to product roles, strategic discussions, and interesting conversations about AI and technology.
      </p>
    </div>

    <!-- Toast notification -->
    <div id="contact-toast" class="contact-toast" role="alert" aria-live="polite"></div>

    <form id="contact-form" class="space-y-5">
      <input type="hidden" name="access_key" value="80a9c1bf-a923-4dc5-8b3f-0fb04fed48b9" />
      <input type="hidden" name="_subject" value="Portfolio Website Email!" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label for="contact-name" class="block text-xs font-body uppercase tracking-wider text-neutral-400 mb-2">Name</label>
          <input id="contact-name" type="text" name="name" required placeholder="Your name" class="form-input" />
        </div>
        <div>
          <label for="contact-email" class="block text-xs font-body uppercase tracking-wider text-neutral-400 mb-2">Email</label>
          <input id="contact-email" type="email" name="email" required placeholder="your@email.com" class="form-input" />
        </div>
      </div>

      <div>
        <label for="contact-message" class="block text-xs font-body uppercase tracking-wider text-neutral-400 mb-2">Message</label>
        <textarea id="contact-message" name="message" required rows="5" placeholder="What's on your mind?" class="form-input resize-none"></textarea>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 pt-2">
        <button type="submit" id="contact-submit"
                class="inline-flex items-center justify-center gap-2 px-8 py-3
                       bg-primary text-[#131313] rounded-lg font-headline text-xs font-bold
                       uppercase tracking-wider hover:bg-primary-dim transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          <span id="contact-submit-text">Send Message</span>
          <Icon name="send" size={17} />
        </button>
        <button type="reset"
                class="px-8 py-3 border border-outline-dim text-neutral-400 rounded-lg
                       font-headline text-xs font-bold uppercase tracking-wider
                       hover:border-neutral-500 hover:text-neutral-300 transition-colors">
          Clear
        </button>
      </div>
    </form>

    <div class="mt-16 pt-10 border-t border-white/5">
      <p class="section-label mb-6">Connect</p>
      <div class="flex flex-wrap gap-6">
        {socials.map(s => (
          <a href={s.href} target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-2 text-neutral-500 hover:text-primary transition-colors text-sm">
            <i class={`${s.icon} text-base`}></i> {s.label}
          </a>
        ))}
        <a href="mailto:singh.kritesh1412@gmail.com"
           class="flex items-center gap-2 text-neutral-500 hover:text-primary transition-colors text-sm">
          <Icon name="mail" size={17} /> Email
        </a>
        <a href={`${base}/photography/`}
           class="flex items-center gap-2 text-neutral-500 hover:text-primary transition-colors text-sm">
          <Icon name="photo_camera" size={17} /> Photography
        </a>
      </div>
    </div>

  </div>
</section>

<script>
  const form       = document.getElementById('contact-form') as HTMLFormElement;
  const toast      = document.getElementById('contact-toast') as HTMLDivElement;
  const submitBtn  = document.getElementById('contact-submit') as HTMLButtonElement;
  const submitText = document.getElementById('contact-submit-text') as HTMLSpanElement;

  function showToast(message: string, type: 'success' | 'error') {
    toast.textContent = message;
    toast.className = `contact-toast contact-toast--${type} contact-toast--visible`;
    setTimeout(() => { toast.className = 'contact-toast'; }, 5000);
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitText.textContent = 'Sending…';

    const data = new FormData(form);
    data.append('botcheck', '');

    try {
      const res  = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: data });
      const json = await res.json();

      if (json.success) {
        showToast('Message sent! I\'ll get back to you soon.', 'success');
        form.reset();
      } else {
        showToast('Something went wrong. Please try again.', 'error');
      }
    } catch {
      showToast('Network error. Please check your connection.', 'error');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Send Message';
    }
  });
</script>
