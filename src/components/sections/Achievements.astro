---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import embassyImg from '../../assets/images/embassyofindia.png';
import cultfitImg  from '../../assets/images/cultfit.png';
import mnnitImg    from '../../assets/images/mnnitlogo.png';

const achievements: {
  logo: ImageMetadata;
  alt: string;
  rounded?: boolean;
  title: string;
  body: string;
}[] = [
  {
    logo: embassyImg,
    alt: 'Embassy of India',
    title: 'Scholarship from the Embassy of India',
    body: 'Merit-based scholarship covering 100% of tuition fees and a monthly stipend, selected from 10,000 applicants with a 1% grant rate by the Embassy of India and EdCil.',
  },
  {
    logo: cultfitImg,
    alt: 'Cult.fit',
    rounded: true,
    title: 'Distance Challenge in Swimming',
    body: 'Exceeded Cult.fit Swimming Distance Challenge by swimming 6.3 KM across five 50-minute sessions — surpassing the 4 KM goal within 2 months of learning to swim.',
  },
  {
    logo: mnnitImg,
    alt: 'MNNIT',
    title: "3rd Place — 'Lapse', Eloquence 2020",
    body: "Secured 3rd rank in 'Lapse' (time-lapse videography) at MNNIT Allahabad's annual literary fest.",
  },
  {
    logo: mnnitImg,
    alt: 'MNNIT',
    title: "3rd Place — 'Once Upon a Time', Eloquence 2020",
    body: "Secured 3rd rank in 'Once Upon a Time' (picture tale photography) at MNNIT Allahabad's annual literary fest.",
  },
];
---

<section id="achievements" class="pt-20 pb-32 px-6 md:px-12 bg-background">
  <div class="max-w-7xl mx-auto">

    <div class="mb-20">
      <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tighter">Achievements</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {achievements.map(a => (
        <div class="bg-surface-mid p-6 rounded-xl border border-outline-dim flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <Image src={a.logo} alt={a.alt} width={36} height={36} loading="eager"
                   class={`object-contain flex-shrink-0 ${a.rounded ? 'rounded-lg' : ''}`} />
            <div class="flex-1 h-px bg-primary/30"></div>
          </div>
          <h3 class="font-headline text-base font-bold">{a.title}</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">{a.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
