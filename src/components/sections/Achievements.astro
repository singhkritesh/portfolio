---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import cultfitImg  from '../../assets/images/cultfit.png';
import mnnitImg    from '../../assets/images/mnnitlogo.png';

const achievements: {
  logo?: ImageMetadata;
  logoSvg?: string;
  alt: string;
  rounded?: boolean;
  title: string;
  body: string;
}[] = [
  {
    logoSvg: `<svg viewBox="0 0 80 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-9 h-9">
      <text x="0" y="28" font-family="Arial Black, sans-serif" font-size="22" font-weight="900" fill="#FF9900">aws</text>
      <path d="M14 36 Q40 44 66 36" stroke="#FF9900" stroke-width="2.5" fill="none" stroke-linecap="round"/>
      <path d="M62 32 L66 36 L62 38" stroke="#FF9900" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    alt: 'AWS',
    title: 'Best Innovation Award — AWS AI Impact 2026',
    body: 'The claims automation platform I built at Care Health Insurance was recognised with the Best Innovation Award at AWS AI Impact 2026 — awarded after my departure, a testament to the platform\'s impact at scale.',
  },
  {
    logo: cultfitImg,
    alt: 'Cult.fit',
    rounded: true,
    title: 'Distance Challenge in Swimming',
    body: 'Exceeded Cult.fit Swimming Distance Challenge by swimming 6.3 KM across five 50-minute sessions, surpassing the 4 KM goal within 2 months of learning to swim.',
  },
  {
    logo: mnnitImg,
    alt: 'MNNIT',
    title: "3rd Place, 'Lapse' at Eloquence 2020",
    body: "Secured 3rd rank in 'Lapse' (time-lapse videography) at MNNIT Allahabad's annual literary fest.",
  },
  {
    logo: mnnitImg,
    alt: 'MNNIT',
    title: "3rd Place, 'Once Upon a Time' at Eloquence 2020",
    body: "Secured 3rd rank in 'Once Upon a Time' (picture tale photography) at MNNIT Allahabad's annual literary fest.",
  },
];
---

<section id="achievements" class="pt-10 pb-32 px-6 md:px-12 bg-background">
  <div class="max-w-7xl mx-auto">

    <div class="mb-10" data-reveal>
      <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter">Achievements</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {achievements.map((a, i) => (
        <div class="bg-surface-mid p-6 rounded-xl border border-outline-dim flex flex-col gap-4"
             data-tilt data-reveal data-reveal-delay={i * 70}>
          <div class="flex items-center gap-3">
            {a.logo
              ? <Image src={a.logo} alt={a.alt} width={144} height={144} loading="eager"
                       class={`w-9 h-9 object-contain flex-shrink-0 ${a.rounded ? 'rounded-lg' : ''}`} />
              : <Fragment set:html={a.logoSvg} />
            }
            <div class="flex-1 h-px bg-primary/30"></div>
          </div>
          <h3 class="font-headline text-base font-bold">{a.title}</h3>
          <p class="text-neutral-600 text-sm leading-relaxed">{a.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
