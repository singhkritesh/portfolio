---
import ProjectsGallery from '../ProjectsGallery.jsx';

const projects = [
  {
    category: 'Ventures',
    tags: [
      { label: 'Climate Tech', accent: true },
      { label: 'Platform Strategy', accent: false },
      { label: 'Zero-to-One', accent: false },
    ],
    title: 'Kangen — Reverse Last-Mile Aggregation',
    bullets: [
      'Building a climate venture targeting the reverse last-mile gap — aggregating waste streams from businesses and municipalities into viable recycling supply chains.',
      'Conducted techno-economic modeling and customer discovery across 20 businesses, 5 industry players, and a municipality pilot to validate unit economics.',
    ],
    date: 'Jan 2026 – Present',
    repo: '',
  },
  {
    category: 'Hackathon',
    tags: [
      { label: 'Growth Strategy', accent: true },
      { label: 'Gen AI', accent: false },
    ],
    title: 'GNOMI — Gen Z Growth Strategy',
    bullets: [
      'Growth Strategy: Designed a Gen Z growth strategy for GNOMI (an AI global-news agent) on two zero-spend loops, a forwardable sourced-answer card and a public @-mention bot, tied to one north-star metric.',
      'Technical Feasibility: Specified the architecture to make it economical: a 10-day vector answer-cache that serves one verified answer to thousands, with citation checks and a multi-platform bot integration.',
    ],
    date: 'June 2026',
    repo: '',
  },
  {
    category: 'Personal Ventures',
    tags: [
      { label: 'Gen AI', accent: true },
      { label: 'Agentic', accent: false },
    ],
    title: 'LinkedIn Content Generation App',
    bullets: [
      'Built an agentic content platform powered by Gemini and Tavily — researches topics in real-time, generates LinkedIn posts, and produces multimodal PPTX decks from a single prompt.',
      'Designed a multi-agent pipeline with tool-calling, web search grounding, and iterative self-critique to improve post quality and audience relevance.',
    ],
    date: 'April 2026',
    repo: 'https://github.com/singhkritesh/linkedin-content-gen',
  },
  {
    category: 'Personal Ventures',
    tags: [
      { label: 'AI Automation', accent: true },
      { label: 'Lead Gen', accent: false },
    ],
    title: 'AI Lead Generation Platform',
    bullets: [
      'Built an AI-driven lead generation application to identify and prioritize high-intent prospects using automated data from Exa APIs.',
      'Designed end-to-end user workflows enabling discovery of leads, auto drafting and sending emails, improving conversion potential.',
    ],
    date: 'March 2026',
    repo: 'https://github.com/singhkritesh/reachout',
  },
  {
    category: 'Personal Ventures',
    tags: [
      { label: 'Local LLM', accent: true },
      { label: 'EdTech', accent: false },
      { label: 'Full PRD', accent: false },
      { label: 'Microservices', accent: false },
    ],
    title: 'AI-First Learning Management System',
    bullets: [
      'Authored PRD for user personas, system architecture, guardrails, and non-functional requirements, and prototyped using Antigravity.',
      'Engineered an interface featuring audio interaction and voice/text queries, powered by a local LLM (Qwen3.5 via Ollama), pgvector for retrieval, and containerized microservices.',
    ],
    date: 'February 2026',
    repo: 'https://github.com/singhkritesh/blank-lms',
  },
  {
    category: 'Academic Projects',
    tags: [
      { label: 'AI Research', accent: true },
      { label: 'Fine-tuning', accent: false },
      { label: 'Python', accent: false },
    ],
    title: 'LLM Hallucination Detection — FastHalluCheck',
    bullets: [
      'Evaluated Vectara HHEM v2 and DeBERTa-v3-small on HaluEval and PHANTOM Financial benchmarks using PyTorch and Hugging Face.',
      'Achieved 98.2% accuracy (F1: 0.9818) with ensemble method on in-domain dataset.',
      'Surfaced key cross-domain generalisation gap (F1 drop of -0.378), showing task-specific training outweighs model scale.',
    ],
    date: 'Dartmouth · 2025',
    repo: 'https://github.com/singhkritesh/ml-assignment',
  },
  {
    category: 'Academic Projects',
    tags: [
      { label: 'Market Analysis', accent: true },
      { label: 'GTM Strategy', accent: false },
      { label: 'Consulting', accent: false },
    ],
    title: 'Graduate Student Consultant — Cisco Spaces',
    bullets: [
      'Conducted market analysis across 5 venue types in the Smart Buildings industry to identify high-potential product launch opportunities.',
      'Aligned customer needs with market trends to inform go-to-market strategy and partner prioritisation for Cisco Spaces.',
    ],
    date: 'Sep – Nov 2025',
    repo: '',
  },
];

const N = projects.length;
---

<!--
  The section is (N+1)×100vh tall to reserve scroll distance.
  .pg-sticky pins to the viewport while the section's scroll space passes,
  giving a natural in-flow entry (no fixed overlay, no fade-in delay).
-->
<section id="projects" class="projects-scroll-space">
  <div class="pg-sticky">
    <ProjectsGallery projects={projects} client:only="react" />
  </div>
</section>

<style>
  .projects-scroll-space {
    height: calc(var(--projects-n, 5) * 40vh + 100vh);
    background: #ffffff;
    position: relative;
  }
  .pg-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
  }
</style>

<script define:vars={{ N }}>
  // Set the CSS variable for section height
  document.getElementById('projects').style.height = `calc(${N} * 40vh + 100vh)`;
</script>

<style is:global>
  /* ── Gallery (fills the sticky viewport) ─────────────────── */
  .pg-gallery {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #ffffff;
  }

  /* ── Meta row (top-left) ─────────────────────────────────── */
  .pg-meta {
    position: absolute;
    top: 17vh;
    left: 5vw;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pg-label {
    font-family: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.05em;
    color: #131313;
  }

  @media (min-width: 768px) {
    .pg-label { font-size: 3rem; }
  }

  @media (min-width: 1024px) {
    .pg-label { font-size: 3.75rem; }
  }

  .pg-counter {
    font-family: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .pg-counter-current {
    color: rgba(0, 0, 0, 0.42);
  }

  .pg-counter-sep,
  .pg-counter-total {
    color: rgba(0, 0, 0, 0.28);
  }

  .pg-category {
    font-family: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.28);
    transition: color 0.4s ease;
  }

  /* ── Progress rail (left side) ───────────────────────────── */
  .pg-rail {
    position: absolute;
    left: 5vw;
    bottom: 10vh;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pg-rail-dot {
    width: 28px;
    height: 2px;
    border-radius: 2px;
    background: #e4e4e4;
    transition: background 0.4s ease, width 0.3s ease;
  }

  .pg-rail-dot--done {
    background: #d0d0d0;
  }

  .pg-rail-dot--active {
    background: #E8A444;
    width: 42px;
  }

  /* ── Card stack (centred) ────────────────────────────────── */
  .pg-stack {
    /* Extra right padding so the stacked cards don't clip */
    padding-right: 80px;
    /* Push card center to ~60% from top */
    margin-top: min(18vh, calc(100vh - 480px), 300px);
  }

  /* ── Card content ────────────────────────────────────────── */
  .pg-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 26px 28px;
    box-sizing: border-box;
  }

  .pg-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 16px;
  }

  .pg-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .pg-tag {
    padding: 3px 9px;
    border-radius: 999px;
    font-family: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: #f0f0f0;
    color: #6b7280;
    border: 1px solid #e4e4e4;
  }

  .pg-tag--accent {
    background: rgba(232, 164, 68, 0.1);
    border-color: rgba(232, 164, 68, 0.3);
    color: #C98830;
  }

  .pg-date {
    font-family: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #b0b0b0;
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .pg-title {
    font-family: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #131313;
    margin: 0 0 14px;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .pg-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
    flex: 1;
    overflow: hidden;
  }

  .pg-bullets li {
    font-family: Inter, sans-serif;
    font-size: 0.76rem;
    color: #6b7280;
    line-height: 1.6;
    padding-left: 12px;
    border-left: 2px solid rgba(232, 164, 68, 0.4);
  }

  .pg-footer {
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid #e4e4e4;
  }

  .pg-repo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .pg-repo:hover {
    color: #131313;
  }

  /* ── Scroll cue ──────────────────────────────────────────── */
  .pg-cue {
    position: absolute;
    bottom: 10vh;
    right: 5vw;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-family: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c0c0c0;
    transition: opacity 0.5s ease;
  }

  .pg-cue--hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* ── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .pg-meta {
      top: 14vh;
      left: 24px;
    }


    .pg-rail {
      flex-direction: row;
      left: 24px;
      bottom: 6vh;
    }

    .pg-rail-dot--active {
      width: 28px;
      height: 3px;
    }

    .pg-stack {
      padding-right: 40px;
      margin-top: 0;
      transform: scale(0.78);
      transform-origin: center center;
    }

    .pg-cue {
      right: 24px;
      bottom: 6vh;
    }
  }
</style>
