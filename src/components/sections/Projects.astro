---
const independent = [
  {
    span: 'md:col-span-7',
    tags: [
      { label: 'Gen AI', accent: true },
      { label: 'Content Strategy', accent: false },
    ],
    title: 'LinkedIn Content Generation App',
    summary: 'Generative AI tool to create personalised LinkedIn content, optimising for audience engagement and content relevance. Designed prompt frameworks, content strategies, and iterative testing workflows.',
    bullets: [
      'Developed a generative AI tool to create personalized LinkedIn content, optimizing for audience engagement and content relevance.',
      'Designed prompt frameworks and content strategies to improve post quality, consistency, and user interaction.',
      'Focused on enhancing user engagement through tailored content recommendations and iterative testing.',
    ],
    date: 'April 2026',
  },
  {
    span: 'md:col-span-5',
    tags: [
      { label: 'AI Automation', accent: true },
      { label: 'Lead Gen', accent: false },
    ],
    title: 'AI Lead Generation Platform',
    summary: 'AI-driven platform using Exa APIs to identify high-intent prospects, auto-draft personalised emails, and score leads through intelligent workflow automation.',
    bullets: [
      'Built an AI-driven lead generation application to identify and prioritize high-intent prospects using automated data from Exa APIs.',
      'Designed end-to-end user workflows enabling discovery of leads, auto drafting and sending emails, improving conversion potential.',
    ],
    date: 'March 2026',
  },
  {
    span: 'md:col-span-12',
    tags: [
      { label: 'Local LLM', accent: true },
      { label: 'EdTech', accent: false },
      { label: 'Full PRD', accent: false },
      { label: 'Microservices', accent: false },
      { label: 'Privacy-First', accent: false },
    ],
    title: 'AI-First Learning Management System',
    summary: 'Authored a full PRD covering user personas, system architecture, guardrails, and non-functional requirements, then prototyped the system. Features audio interaction and voice/text queries for real-time course access. Powered by Qwen 3.5 via Ollama, pgvector for retrieval, and containerised microservices.',
    bullets: [
      'Authored PRD for user personas, system architecture, guardrails, and non-functional requirements, and prototyped using Antigravity.',
      'Engineered an interface featuring audio interaction and voice/text queries, enabling real-time course access to enhance the student education experience, powered by a local LLM (Qwen3.5 via Ollama), pgvector for retrieval, and containerized microservices.',
    ],
    date: 'February 2026',
  },
];

const academic = [
  {
    span: 'md:col-span-6',
    tags: [
      { label: 'AI Research', accent: true },
      { label: 'Fine-tuning', accent: false },
      { label: 'Python', accent: false },
    ],
    title: 'LLM Hallucination Detection — FastHalluCheck',
    summary: 'Research project evaluating hallucination detection models on QA benchmarks using threshold optimisation and supervised fine-tuning. Explored ensemble approaches across in-domain and cross-domain datasets.',
    bullets: [
      'Evaluated Vectara HHEM v2 and DeBERTa-v3-small on HaluEval and PHANTOM Financial benchmarks using PyTorch and Hugging Face.',
      'Achieved 98.2% accuracy (F1: 0.9818) with ensemble method on in-domain dataset.',
      'Surfaced key cross-domain generalisation gap (F1 drop of -0.378), showing task-specific training outweighs model scale.',
    ],
    date: 'Dartmouth · 2025',
  },
  {
    span: 'md:col-span-6',
    tags: [
      { label: 'Market Analysis', accent: true },
      { label: 'GTM Strategy', accent: false },
      { label: 'Consulting', accent: false },
    ],
    title: 'Graduate Student Consultant — Cisco Spaces',
    summary: 'Consulted on product strategy in the $20B Smart Buildings industry, identifying high-potential launch opportunities across 5 venue types and informing go-to-market and partner prioritisation for Cisco Spaces.',
    bullets: [
      'Conducted market analysis across 5 venue types in the Smart Buildings industry to identify high-potential product launch opportunities.',
      'Aligned customer needs with market trends to inform go-to-market strategy and partner prioritisation for Cisco Spaces.',
    ],
    date: 'Sep – Nov 2025',
  },
];

const allProjects = [...independent, ...academic];
---

<section id="projects" class="pt-20 pb-32 px-6 md:px-12 bg-background">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-20" data-reveal>
      <div>
        <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter">
          Projects
        </h2>
      </div>
      <p class="text-neutral-500 text-sm max-w-xs leading-relaxed">
        Personal builds and academic work at the intersection of AI, product thinking, and engineering.
      </p>
    </div>

    <!-- Independent Builds -->
    <div class="mb-16">
      <p class="font-headline text-lg font-semibold tracking-tight text-neutral-300 mb-6" data-reveal>Personal Ventures</p>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        {independent.map((p, i) => (
          <div
            class={`${p.span} proj-card bg-surface-mid rounded-xl border border-outline-dim flex flex-col bento-card cursor-default`}
            data-proj-idx={i}
            data-reveal data-reveal-delay={i * 80}
          >
            <div class="p-8 flex flex-col flex-1 w-full">
              <div class="flex flex-wrap items-center gap-2 mb-6">
                {p.tags.map(t => (
                  <span class={`px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider ${t.accent ? 'bg-primary/10 border border-primary/20 text-primary' : 'bg-surface-high text-neutral-400'}`}>
                    {t.label}
                  </span>
                ))}
                <span class="ml-auto text-[10px] font-headline uppercase tracking-wider text-neutral-500">{p.date}</span>
              </div>
              <div class="flex flex-col flex-1">
                <h3 class="font-headline text-xl md:text-2xl font-bold mb-3">{p.title}</h3>
                <p class="text-neutral-400 text-sm leading-relaxed">{p.summary}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Academic Projects -->
    <div>
      <p class="font-headline text-lg font-semibold tracking-tight text-neutral-300 mb-6" data-reveal>Academic Projects</p>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        {academic.map((p, i) => (
          <div
            class={`${p.span} proj-card bg-surface-mid rounded-xl border border-outline-dim flex flex-col bento-card cursor-default`}
            data-proj-idx={independent.length + i}
            data-reveal data-reveal-delay={i * 80}
          >
            <div class="p-8 flex flex-col flex-1 w-full">
              <div class="flex flex-wrap items-center gap-2 mb-6">
                {p.tags.map(t => (
                  <span class={`px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider ${t.accent ? 'bg-primary/10 border border-primary/20 text-primary' : 'bg-surface-high text-neutral-400'}`}>
                    {t.label}
                  </span>
                ))}
                <span class="ml-auto text-[10px] font-headline uppercase tracking-wider text-neutral-500">{p.date}</span>
              </div>
              <div class="flex flex-col flex-1">
                <h3 class="font-headline text-xl md:text-2xl font-bold mb-3">{p.title}</h3>
                <p class="text-neutral-400 text-sm leading-relaxed">{p.summary}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Detail strip -->
    <div id="proj-detail"
         class="mt-10 border-t border-outline-dim pt-8"
         style="opacity:0; transition: opacity 0.2s ease;">
      <div class="flex flex-wrap items-baseline justify-between gap-4 mb-5">
        <h4 id="proj-detail-title" class="font-headline text-lg font-bold"></h4>
        <span id="proj-detail-date" class="text-[10px] font-headline uppercase tracking-wider text-neutral-500"></span>
      </div>
      <ul id="proj-detail-bullets" class="grid grid-cols-1 md:grid-cols-2 gap-4"></ul>
    </div>

  </div>
</section>

<script>
  const projectData = [
    {
      title: 'LinkedIn Content Generation App',
      bullets: [
        'Developed a generative AI tool to create personalized LinkedIn content, optimizing for audience engagement and content relevance.',
        'Designed prompt frameworks and content strategies to improve post quality, consistency, and user interaction.',
        'Focused on enhancing user engagement through tailored content recommendations and iterative testing.',
      ],
      date: 'April 2026',
    },
    {
      title: 'AI Lead Generation Platform',
      bullets: [
        'Built an AI-driven lead generation application to identify and prioritize high-intent prospects using automated data from Exa APIs.',
        'Designed end-to-end user workflows enabling discovery of leads, auto drafting and sending emails, improving conversion potential.',
      ],
      date: 'March 2026',
    },
    {
      title: 'AI-First Learning Management System',
      bullets: [
        'Authored PRD for user personas, system architecture, guardrails, and non-functional requirements, and prototyped using Antigravity.',
        'Engineered an interface featuring audio interaction and voice/text queries, enabling real-time course access, powered by a local LLM (Qwen3.5 via Ollama), pgvector for retrieval, and containerized microservices.',
      ],
      date: 'February 2026',
    },
    {
      title: 'LLM Hallucination Detection — FastHalluCheck',
      bullets: [
        'Evaluated Vectara HHEM v2 and DeBERTa-v3-small on HaluEval and PHANTOM Financial benchmarks using PyTorch and Hugging Face.',
        'Achieved 98.2% accuracy (F1: 0.9818) with ensemble method on in-domain dataset.',
        'Surfaced key cross-domain generalisation gap (F1 drop of -0.378), showing task-specific training outweighs model scale.',
      ],
      date: 'Dartmouth · 2025',
    },
    {
      title: 'Graduate Student Consultant — Cisco Spaces',
      bullets: [
        'Conducted market analysis across 5 venue types in the Smart Buildings industry to identify high-potential product launch opportunities.',
        'Aligned customer needs with market trends to inform go-to-market strategy and partner prioritisation for Cisco Spaces.',
      ],
      date: 'Sep – Nov 2025',
    },
  ];

  const allCards  = Array.from(document.querySelectorAll<HTMLElement>('.proj-card'));
  const detail    = document.getElementById('proj-detail')!;
  const titleEl   = document.getElementById('proj-detail-title')!;
  const dateEl    = document.getElementById('proj-detail-date')!;
  const bulletsEl = document.getElementById('proj-detail-bullets')!;

  let activeIdx   = -1;
  let leaveTimer: ReturnType<typeof setTimeout> | null = null;

  function show(idx: number) {
    if (leaveTimer) { clearTimeout(leaveTimer); leaveTimer = null; }

    // Spotlight
    allCards.forEach((c, i) => {
      c.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
      c.style.opacity    = i === idx ? '1' : '0.35';
      c.style.transform  = i === idx ? 'scale(1.015)' : 'scale(1)';
    });

    if (idx !== activeIdx) {
      activeIdx = idx;
      const p = projectData[idx];
      titleEl.textContent = p.title;
      dateEl.textContent  = p.date;
      bulletsEl.innerHTML = p.bullets.map((b, i) =>
        `<li class="text-sm text-neutral-300 leading-relaxed border-l-2 border-primary/40 pl-3"
             style="animation: bulletIn 0.25s ease both; animation-delay: ${i * 60}ms">${b}</li>`
      ).join('');
    }

    detail.style.opacity = '1';
  }

  function hide() {
    leaveTimer = setTimeout(() => {
      allCards.forEach((c) => {
        c.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
        c.style.opacity    = '1';
        c.style.transform  = 'scale(1)';
      });
      detail.style.opacity = '0';
      activeIdx = -1;
    }, 150);
  }

  allCards.forEach((card) => {
    card.addEventListener('mouseenter', () => show(Number(card.dataset.projIdx)));
    card.addEventListener('mouseleave', hide);
  });
</script>

<style>
  @keyframes bulletIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
