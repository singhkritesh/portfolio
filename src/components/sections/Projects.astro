<script>
  document.querySelectorAll<HTMLElement>('.card-flip-wrapper').forEach(wrapper => {
    const inner = wrapper.querySelector<HTMLElement>('.card-flip-inner');
    const bullets = Array.from(wrapper.querySelectorAll<HTMLElement>('.card-back li'));

    function animateBulletsIn() {
      bullets.forEach((li, i) => {
        li.style.animation = 'none';
        li.offsetHeight; // force reflow — resets the animation
        li.style.animation = `bulletIn 0.32s ease both ${350 + i * 70}ms`;
      });
    }

    function resetBullets() {
      bullets.forEach(li => {
        li.style.animation = 'none';
        li.style.opacity = '0';
      });
    }

    wrapper.addEventListener('click', e => {
      const t = e.target as Element;
      if (t.closest('a') || t.closest('.flip-back')) return;
      const flipping = !inner?.classList.contains('flipped');
      inner?.classList.toggle('flipped');
      wrapper.classList.toggle('is-flipped');
      if (flipping) animateBulletsIn(); else resetBullets();
    });

    wrapper.querySelector('.flip-back')?.addEventListener('click', e => {
      e.stopPropagation();
      inner?.classList.remove('flipped');
      wrapper.classList.remove('is-flipped');
      resetBullets();
    });
  });
</script>

<style>
  .card-flip-wrapper {
    perspective: 1200px;
    cursor: pointer;
    transition: transform 0.25s ease;
  }
  .card-flip-wrapper:not(.is-flipped):hover {
    transform: translateY(-2px);
  }

  .card-flip-inner {
    display: grid;
    transform-style: preserve-3d;
    transition: transform 0.65s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .card-flip-inner.flipped {
    transform: rotateY(180deg);
  }

  .card-face {
    grid-area: 1 / 1;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transition: border-color 0.35s ease, box-shadow 0.35s ease;
    box-shadow: inset 0 1px rgba(255, 255, 255, 0.06);
    min-height: 260px;
  }
  .card-back {
    transform: rotateY(180deg);
  }

  .card-flip-wrapper:not(.is-flipped):hover .card-front {
    border-color: rgba(232, 164, 68, 0.22);
    box-shadow:
      0 0 0 1px rgba(232, 164, 68, 0.06),
      0 8px 32px -8px rgba(232, 164, 68, 0.12),
      0 2px 8px -2px rgba(0, 0, 0, 0.4),
      inset 0 1px rgba(255, 255, 255, 0.06);
  }
  .card-flip-wrapper.is-flipped:hover .card-back {
    border-color: rgba(232, 164, 68, 0.22);
  }

  .card-back li {
    opacity: 0;
  }

  @keyframes bulletIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .flip-hint {
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .card-flip-wrapper:not(.is-flipped):hover .flip-hint {
    opacity: 1;
    transform: translateY(0);
  }
</style>
