---
import Icon from '../Icon.astro';
---

<section id="home" class="relative min-h-screen flex flex-col justify-center
                           px-6 md:px-12 pt-28 pb-24 overflow-hidden">

  <div class="absolute inset-0 dot-grid opacity-100 pointer-events-none"></div>
  <div class="absolute top-1/3 right-0 w-[420px] h-[420px] bg-primary opacity-[0.04]
              blur-[100px] rounded-full pointer-events-none"></div>
  <div class="absolute bottom-0 left-1/4 w-64 h-64 bg-primary opacity-[0.03]
              blur-[80px] rounded-full pointer-events-none"></div>

  <div class="relative z-10 max-w-5xl">

    <h1 class="font-headline font-bold tracking-tighter leading-[0.88] mb-8
               text-6xl sm:text-7xl md:text-8xl lg:text-[9rem]">
      Kritesh<br />
      <span class="text-primary">Singh.</span>
    </h1>

    <p class="font-body text-lg md:text-xl text-neutral-400 max-w-2xl leading-relaxed font-light mb-12"
       data-reveal data-reveal-delay="50">
      Product Manager with 4+ years of experience building AI native, customer centric products. Passionate about building the product experience of tomorrow.
    </p>

    <div class="flex flex-wrap gap-4 mb-16" data-reveal data-reveal-delay="80">
      <a href="#work"
         class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-[#131313]
                rounded-lg font-headline text-xs font-bold uppercase tracking-wider
                hover:bg-primary-dim transition-colors">
        View My Work
        <Icon name="arrow_forward" size={17} />
      </a>
      <a href="#contact"
         class="inline-flex items-center gap-2 px-6 py-3 bg-background border border-neutral-700
                text-neutral-300 rounded-lg font-headline text-xs font-bold uppercase
                tracking-wider hover:border-primary hover:text-white transition-colors">
        Get in Touch
      </a>
    </div>

    <div class="flex flex-wrap gap-10 md:gap-16 pt-8 border-t border-white/5" data-reveal data-reveal-delay="120">
      <div>
        <div class="font-headline text-4xl font-bold stat-number">4+</div>
        <div class="font-body text-[10px] uppercase tracking-widest text-neutral-400 mt-1">Years PM Experience</div>
      </div>
      <div>
        <div class="font-headline text-4xl font-bold stat-number">$1.1M</div>
        <div class="font-body text-[10px] uppercase tracking-widest text-neutral-400 mt-1">Annual Savings Delivered</div>
      </div>
      <div>
        <div class="font-headline text-4xl font-bold stat-number">AI/ML</div>
        <div class="font-body text-[10px] uppercase tracking-widest text-neutral-400 mt-1">Core Specialisation</div>
      </div>
      <div>
        <div class="font-headline text-4xl font-bold stat-number">Dartmouth</div>
        <div class="font-body text-[10px] uppercase tracking-widest text-neutral-400 mt-1">MEM · Thayer + Tuck</div>
      </div>
    </div>

  </div>
</section>
