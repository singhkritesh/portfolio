---
import Icon from '../Icon.astro';
import Magnet from '../Magnet.astro';
---

<section id="home" class="relative min-h-screen flex flex-col justify-center
                           px-6 md:px-12 pt-28 pb-24 overflow-hidden">
  <span id="main-content" aria-hidden="true" class="sr-only"></span>

  <canvas id="hero-dot-canvas" class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></canvas>

  <div class="relative z-10 max-w-5xl">

    <h1 class="font-headline font-bold tracking-tighter leading-[0.88] mb-8
               text-6xl sm:text-7xl md:text-8xl lg:text-[9rem]">
      Kritesh<br />
      <span class="text-primary">Singh.</span>
    </h1>

    <p class="font-body text-lg md:text-xl text-neutral-600 max-w-2xl leading-relaxed font-light mb-12"
       data-reveal data-reveal-delay="50">
      Product Manager with 4+ years of experience building AI native, customer centric products. Passionate about building the product experience of tomorrow.
    </p>

    <div class="flex flex-wrap gap-4 mb-10" data-reveal data-reveal-delay="80">
      <Magnet padding={40} magnetStrength={8} maxDisplacement={6}>
        <a href="#work"
           class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-[#131313]
                  rounded-lg font-headline text-xs font-bold uppercase tracking-wider
                  hover:bg-primary-dim transition-colors">
          View My Work
          <Icon name="arrow_forward" size={17} />
        </a>
      </Magnet>
      <Magnet padding={40} magnetStrength={8} maxDisplacement={6}>
        <a href="#contact"
           class="inline-flex items-center gap-2 px-6 py-3 bg-background border border-neutral-300
                  text-neutral-700 rounded-lg font-headline text-xs font-bold uppercase
                  tracking-wider hover:border-primary hover:text-neutral-900 transition-colors">
          Get in Touch
        </a>
      </Magnet>
    </div>

    <div class="flex flex-wrap gap-10 md:gap-16 pt-6" data-reveal data-reveal-delay="120">
      <div>
        <div class="font-headline text-4xl font-bold stat-number">4+</div>
        <div class="font-body text-[10px] uppercase tracking-widest text-neutral-500 mt-1">Years PM Experience</div>
      </div>
      <div>
        <div class="font-headline text-4xl font-bold stat-number">$1.1M</div>
        <div class="font-body text-[10px] uppercase tracking-widest text-neutral-500 mt-1">Annual Savings Delivered</div>
      </div>
      <div>
        <div class="font-headline text-4xl font-bold stat-number">6</div>
        <div class="font-body text-[10px] uppercase tracking-widest text-neutral-500 mt-1">AI Product Portfolio</div>
      </div>
      <div>
        <div class="font-headline text-4xl font-bold stat-number">Dartmouth</div>
        <div class="font-body text-[10px] uppercase tracking-widest text-neutral-500 mt-1">MEM · Thayer + Tuck</div>
      </div>
    </div>

  </div>
</section>

<script>
  const canvas = document.getElementById('hero-dot-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const dpr = window.devicePixelRatio || 1;

  let mX = -99999, mY = -99999;

  function resize() {
    const rect = canvas.getBoundingClientRect();
    canvas.width  = rect.width  * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);
  }
  resize();
  window.addEventListener('resize', () => { ctx.resetTransform(); resize(); }, { passive: true });

  window.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mX = e.clientX - rect.left;
    mY = e.clientY - rect.top;
  }, { passive: true });

  window.addEventListener('mouseleave', () => { mX = -99999; mY = -99999; });

  const SPACING  = 28;
  const STRENGTH = 2800;
  const SOFTEN   = 55;   // prevents singularity when cursor is on a dot
  const MAX_DISP = 38;
  const DOT_R    = 0.8;

  let rafId = 0;

  function draw() {
    const w = canvas.width  / dpr;
    const h = canvas.height / dpr;
    ctx.clearRect(0, 0, w, h);
    ctx.fillStyle = 'rgba(232, 164, 68, 0.38)';

    const cols = Math.ceil(w / SPACING) + 2;
    const rows = Math.ceil(h / SPACING) + 2;

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const bx = c * SPACING;
        const by = r * SPACING;
        const dx = mX - bx;
        const dy = mY - by;
        const factor = STRENGTH / (dx * dx + dy * dy + SOFTEN * SOFTEN);
        const ox = Math.min(Math.max(dx * factor, -MAX_DISP), MAX_DISP);
        const oy = Math.min(Math.max(dy * factor, -MAX_DISP), MAX_DISP);
        ctx.beginPath();
        ctx.arc(bx + ox, by + oy, DOT_R, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    rafId = requestAnimationFrame(draw);
  }

  // Pause the loop when hero is off-screen to save CPU
  const heroObs = new IntersectionObserver(([entry]) => {
    if (entry.isIntersecting) {
      if (!rafId) draw();
    } else {
      cancelAnimationFrame(rafId);
      rafId = 0;
    }
  }, { threshold: 0 });

  heroObs.observe(canvas);
</script>
