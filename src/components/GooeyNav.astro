---
interface NavItem {
  label: string;
  href: string;
  section?: string;
}

interface Props {
  items: NavItem[];
  particleCount?: number;
  particleDistances?: [number, number];
  particleR?: number;
  animationTime?: number;
  timeVariance?: number;
  colors?: number[];
  initialActiveIndex?: number;
}

const {
  items,
  particleCount = 15,
  particleDistances = [90, 10],
  particleR = 100,
  animationTime = 600,
  timeVariance = 300,
  colors = [1, 2, 3, 1, 2, 3, 1, 4],
  initialActiveIndex = 0,
} = Astro.props;
---

<div class="gooey-nav-container" id="gooey-nav">
  <nav>
    <ul id="gooey-ul">
      {items.map((item, i) => (
        <li
          class={`gooey-item${i === initialActiveIndex ? ' active' : ''}`}
          data-index={String(i)}
          data-section={item.section ?? ''}
        >
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
  <span class="effect filter" id="gooey-filter"></span>
  <span class="effect text"   id="gooey-text"></span>
</div>

<style is:global>
  .gooey-nav-container {
    --color-1: #131313;
    --color-2: #131313;
    --color-3: #131313;
    --color-4: #131313;
    position: relative;
  }

  .gooey-nav-container nav {
    display: flex;
    position: relative;
    transform: translate3d(0, 0, 0.01px);
  }

  .gooey-nav-container nav ul {
    display: flex;
    gap: 0.25em;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    z-index: 3;
  }

  .gooey-nav-container nav ul li {
    border-radius: 100vw;
    position: relative;
    cursor: pointer;
    color: #6b7280;
    transition: color 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 0 0.5px 1.5px transparent;
  }

  .gooey-nav-container nav ul li a {
    display: inline-block;
    padding: 0.45em 0.85em;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
  }

  .gooey-nav-container nav ul li:focus-within:has(:focus-visible) {
    box-shadow: 0 0 0.5px 1.5px #E8A444;
  }

  /* Static dark pill behind active item text */
  .gooey-nav-container nav ul li::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 100vw;
    background: #131313;
    opacity: 0;
    transform: scale(0);
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: -1;
  }

  .gooey-nav-container nav ul li.active {
    color: white;
  }

  .gooey-nav-container nav ul li.active::after {
    opacity: 1;
    transform: scale(1);
  }

  /* Effect overlay elements */
  .gooey-nav-container .effect {
    position: absolute;
    left: 0;
    top: 0;
    width: 0;
    height: 0;
    opacity: 1;
    pointer-events: none;
    display: grid;
    place-items: center;
    z-index: 1;
  }

  .gooey-nav-container .effect.text {
    color: white;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    z-index: 4;
  }

  /* Gooey filter: blur+contrast creates the blobby merge effect */
  .gooey-nav-container .effect.filter {
    filter: blur(7px) contrast(100) blur(0);
    mix-blend-mode: multiply;
  }

  /* White bg — with multiply blend, white × page = page (invisible field).
     Dark blobs (pill + particles) × white page = dark (visible pill). */
  .gooey-nav-container .effect.filter::before {
    content: '';
    position: absolute;
    top: -75px;
    left: -75px;
    right: -75px;
    bottom: 0;
    z-index: -2;
    background: white;
  }

  /* Dark animated pill inside the filter layer */
  .gooey-nav-container .effect.filter::after {
    content: '';
    position: absolute;
    inset: 0;
    background: #131313;
    transform: scale(0);
    opacity: 0;
    z-index: -1;
    border-radius: 100vw;
  }

  .gooey-nav-container .effect.active::after {
    animation: gooey-pill 0.3s ease both;
  }

  @keyframes gooey-pill {
    to { transform: scale(1); opacity: 1; }
  }

  /* Particles */
  .gooey-particle,
  .gooey-point {
    display: block;
    opacity: 0;
    width: 20px;
    height: 20px;
    border-radius: 100%;
    transform-origin: center;
  }

  .gooey-particle {
    --time: 5s;
    position: absolute;
    top: calc(50% - 8px);
    left: calc(50% - 8px);
    animation: gooey-particle-anim calc(var(--time)) ease 1 -350ms;
  }

  .gooey-point {
    background: var(--color);
    opacity: 1;
    animation: gooey-point-anim calc(var(--time)) ease 1 -350ms;
  }

  @keyframes gooey-particle-anim {
    0% {
      transform: rotate(0deg) translate(var(--start-x), var(--start-y));
      opacity: 1;
      animation-timing-function: cubic-bezier(0.55, 0, 1, 0.45);
    }
    70% {
      transform: rotate(calc(var(--rotate) * 0.5))
                 translate(calc(var(--end-x) * 1.2), calc(var(--end-y) * 1.2));
      opacity: 1;
      animation-timing-function: ease;
    }
    85% {
      transform: rotate(calc(var(--rotate) * 0.66))
                 translate(var(--end-x), var(--end-y));
      opacity: 1;
    }
    100% {
      transform: rotate(calc(var(--rotate) * 1.2))
                 translate(calc(var(--end-x) * 0.5), calc(var(--end-y) * 0.5));
      opacity: 1;
    }
  }

  @keyframes gooey-point-anim {
    0%  { transform: scale(0); opacity: 0;
          animation-timing-function: cubic-bezier(0.55, 0, 1, 0.45); }
    25% { transform: scale(calc(var(--scale) * 0.25)); }
    38% { opacity: 1; }
    65% { transform: scale(var(--scale)); opacity: 1;
          animation-timing-function: ease; }
    85% { transform: scale(var(--scale)); opacity: 1; }
    100%{ transform: scale(0); opacity: 0; }
  }
</style>

<script define:vars={{ particleCount, particleDistances, particleR, animationTime, timeVariance, colors, initialActiveIndex }}>
  const container = document.getElementById('gooey-nav');
  const filterEl  = document.getElementById('gooey-filter');
  const textEl    = document.getElementById('gooey-text');
  const listItems = Array.from(container.querySelectorAll('.gooey-item'));

  let activeIndex = initialActiveIndex;

  // ── Math helpers ────────────────────────────────────────────
  const noise = (n = 1) => n / 2 - Math.random() * n;

  function getXY(distance, pointIndex, totalPoints) {
    const angle = ((360 + noise(8)) / totalPoints) * pointIndex * (Math.PI / 180);
    return [distance * Math.cos(angle), distance * Math.sin(angle)];
  }

  function createParticle(i, t, d, r) {
    const rotate = noise(r / 10);
    return {
      start: getXY(d[0], particleCount - i, particleCount),
      end:   getXY(d[1] + noise(7), particleCount - i, particleCount),
      time:  t,
      scale: 1 + noise(0.2),
      color: colors[Math.floor(Math.random() * colors.length)],
      rotate: rotate > 0 ? (rotate + r / 20) * 10 : (rotate - r / 20) * 10,
    };
  }

  // ── Particle spawner ────────────────────────────────────────
  function makeParticles(element) {
    const d = particleDistances;
    const r = particleR;
    element.style.setProperty('--time', `${animationTime * 2 + timeVariance}ms`);
    element.classList.remove('active');

    for (let i = 0; i < particleCount; i++) {
      const t = animationTime * 2 + noise(timeVariance * 2);
      const p = createParticle(i, t, d, r);

      setTimeout(() => {
        const particle = document.createElement('span');
        const point    = document.createElement('span');
        particle.classList.add('gooey-particle');
        particle.style.setProperty('--start-x', `${p.start[0]}px`);
        particle.style.setProperty('--start-y', `${p.start[1]}px`);
        particle.style.setProperty('--end-x',   `${p.end[0]}px`);
        particle.style.setProperty('--end-y',   `${p.end[1]}px`);
        particle.style.setProperty('--time',    `${p.time}ms`);
        particle.style.setProperty('--scale',   `${p.scale}`);
        particle.style.setProperty('--color',   `var(--color-${p.color}, #E8A444)`);
        particle.style.setProperty('--rotate',  `${p.rotate}deg`);
        point.classList.add('gooey-point');
        particle.appendChild(point);
        element.appendChild(particle);
        setTimeout(() => {
          try { element.removeChild(particle); } catch {}
        }, t);
      }, 30);
    }

    setTimeout(() => requestAnimationFrame(() => element.classList.add('active')), 30);
  }

  // ── Pill position ───────────────────────────────────────────
  function updateEffectPosition(li) {
    if (!container || !filterEl || !textEl) return;
    const cRect = container.getBoundingClientRect();
    const pos   = li.getBoundingClientRect();
    const styles = {
      left:   `${pos.x - cRect.x}px`,
      top:    `${pos.y - cRect.y}px`,
      width:  `${pos.width}px`,
      height: `${pos.height}px`,
    };
    Object.assign(filterEl.style, styles);
    Object.assign(textEl.style,   styles);
    textEl.innerText = li.querySelector('a').innerText;
  }

  // ── Activate item ───────────────────────────────────────────
  function activateItem(index, withParticles) {
    if (index < 0 || index >= listItems.length) return;
    if (index === activeIndex) return;

    listItems.forEach((li, i) => li.classList.toggle('active', i === index));
    activeIndex = index;

    const activeLi = listItems[index];
    updateEffectPosition(activeLi);

    if (withParticles) {
      filterEl.querySelectorAll('.gooey-particle').forEach(p => {
        try { filterEl.removeChild(p); } catch {}
      });
      makeParticles(filterEl);
    } else {
      filterEl.classList.add('active');
    }
  }

  // ── Click handlers ──────────────────────────────────────────
  listItems.forEach((li, i) => {
    const href = li.querySelector('a')?.getAttribute('href') ?? '';
    const isPageLink = !href.includes('#');
    // Page links navigate immediately — particles would be cut off, so skip them.
    // Hash links stay on the page and can show the full burst animation.
    li.addEventListener('click', () => activateItem(i, !isPageLink));
  });

  // ── Scrollspy ───────────────────────────────────────────────
  const pageSections = listItems
    .map((li, i) => ({
      index: i,
      el: li.dataset.section ? document.getElementById(li.dataset.section) : null,
    }))
    .filter(s => s.el);

  function currentSectionIndex() {
    if (pageSections.length === 0) return -1;
    const threshold = window.innerHeight * 0.4;
    let current = pageSections[0];
    for (const s of pageSections) {
      if (s.el.getBoundingClientRect().top < threshold) current = s;
      else break;
    }
    return current.index;
  }

  let scrollRaf = 0;
  window.addEventListener('scroll', () => {
    if (document.body.classList.contains('show-photography')) return;
    if (scrollRaf) cancelAnimationFrame(scrollRaf);
    scrollRaf = requestAnimationFrame(() => {
      const idx = currentSectionIndex();
      if (idx >= 0 && idx !== activeIndex) activateItem(idx, false);
    });
  }, { passive: true });

  // ── Resize: reposition pill ─────────────────────────────────
  const ro = new ResizeObserver(() => {
    if (listItems[activeIndex]) updateEffectPosition(listItems[activeIndex]);
  });
  ro.observe(container);

  // ── Init ────────────────────────────────────────────────────
  // Two rAF ticks so the nav has painted and getBoundingClientRect is valid.
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      // On non-section pages (e.g. photography), find matching item by href
      if (pageSections.length === 0) {
        const path = window.location.pathname;
        const pageIdx = listItems.findIndex(li => {
          const href = li.querySelector('a')?.getAttribute('href') ?? '';
          return !href.includes('#') && href.length > 1 && path.includes(
            href.replace(/^\/portfolio/, '').replace(/\/$/, '')
          );
        });
        activateItem(pageIdx >= 0 ? pageIdx : initialActiveIndex, false);
      } else {
        const idx = currentSectionIndex();
        activateItem(idx >= 0 ? idx : initialActiveIndex, false);
      }
    });
  });
</script>
