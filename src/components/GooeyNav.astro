---
interface NavItem {
  label: string;
  href: string;
  section?: string;
}

interface Props {
  items: NavItem[];
  particleCount?: number;
  particleDistances?: [number, number];
  particleR?: number;
  animationTime?: number;
  timeVariance?: number;
  colors?: number[];
  initialActiveIndex?: number;
}

const {
  items,
  particleCount = 15,
  particleDistances = [90, 10],
  particleR = 100,
  animationTime = 600,
  timeVariance = 300,
  colors = [1, 2, 3, 1, 2, 3, 1, 4],
  initialActiveIndex = 0,
} = Astro.props;
---

<div class="gooey-nav-container" id="gooey-nav">
  <nav>
    <ul id="gooey-ul">
      {items.map((item, i) => (
        <li
          class={`gooey-item${i === initialActiveIndex ? ' active' : ''}`}
          data-index={String(i)}
          data-section={item.section ?? ''}
        >
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
  <div class="slider-pill" id="slider-pill"></div>
  <span class="effect filter" id="gooey-filter"></span>
</div>

<style is:global>
  .gooey-nav-container {
    --color-1: #131313;
    --color-2: #131313;
    --color-3: #131313;
    --color-4: #131313;
    position: relative;
  }

  .gooey-nav-container nav {
    display: flex;
    position: relative;
    transform: translate3d(0, 0, 0.01px);
    z-index: 2;
  }

  .gooey-nav-container nav ul {
    display: flex;
    gap: 0.25em;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    z-index: 3;
  }

  .gooey-nav-container nav ul li {
    border-radius: 100vw;
    position: relative;
    cursor: pointer;
    color: #6b7280;
    transition: box-shadow 0.3s ease;
    box-shadow: 0 0 0.5px 1.5px transparent;
  }

  .gooey-nav-container nav ul li a {
    display: inline-block;
    padding: 0.45em 0.85em;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
  }

  .gooey-nav-container nav ul li:focus-within:has(:focus-visible) {
    box-shadow: 0 0 0.5px 1.5px #E8A444;
  }

  /* Effect overlay elements */
  .gooey-nav-container .effect {
    position: absolute;
    left: 0;
    top: 0;
    width: 0;
    height: 0;
    opacity: 1;
    pointer-events: none;
    display: grid;
    place-items: center;
    z-index: 1;
    /* No CSS transitions — pill position is set directly by the real-time scrubber */
  }

  /* Gooey filter: blur+contrast creates the blobby merge effect */
  .gooey-nav-container .effect.filter {
    filter: blur(7px) contrast(100) blur(0);
    mix-blend-mode: multiply;
  }

  /* White bg — with multiply blend, white × page = page (invisible field).
     Dark blobs (pill + particles) × white page = dark (visible pill). */
  .gooey-nav-container .effect.filter::before {
    content: '';
    position: absolute;
    top: -75px;
    left: -75px;
    right: -75px;
    bottom: 0;
    z-index: -2;
    background: white;
  }

  /* Dark animated pill inside the filter layer */
  .gooey-nav-container .effect.filter::after {
    content: '';
    position: absolute;
    inset: 0;
    background: #131313;
    transform: scale(0);
    opacity: 0;
    z-index: -1;
    border-radius: 100vw;
  }

  .gooey-nav-container .effect.active::after {
    animation: gooey-pill 0.9s forwards;
  }

  /* Scroll position indicator — opaque dark pill behind nav text (DOM order keeps text on top) */
  .gooey-nav-container .slider-pill {
    position: absolute;
    left: 0;
    top: 0;
    width: 0;
    height: 0;
    border-radius: 100vw;
    background: linear-gradient(180deg, #252525 0%, #131313 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 1px 3px rgba(0, 0, 0, 0.35),
      0 4px 16px rgba(0, 0, 0, 0.4);
    pointer-events: none;
    z-index: 0;
    transition: opacity 0.2s ease;
    will-change: transform;
  }

  @keyframes gooey-pill {
    0%   { transform: scale(0);   opacity: 0; animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1); }
    45%  { transform: scale(1);   opacity: 1; animation-timing-function: ease; }
    55%  { transform: scale(1);   opacity: 1; animation-timing-function: ease-in; }
    100% { transform: scale(0.7); opacity: 0; }
  }

  /* Particles */
  .gooey-particle,
  .gooey-point {
    display: block;
    opacity: 0;
    width: 20px;
    height: 20px;
    border-radius: 100%;
    transform-origin: center;
  }

  .gooey-particle {
    --time: 5s;
    position: absolute;
    top: calc(50% - 8px);
    left: calc(50% - 8px);
    animation: gooey-particle-anim calc(var(--time)) ease 1 -350ms;
  }

  .gooey-point {
    background: var(--color);
    opacity: 1;
    animation: gooey-point-anim calc(var(--time)) ease 1 -350ms;
  }

  @keyframes gooey-particle-anim {
    0% {
      transform: rotate(0deg) translate(var(--start-x), var(--start-y));
      opacity: 1;
      animation-timing-function: cubic-bezier(0.55, 0, 1, 0.45);
    }
    70% {
      transform: rotate(calc(var(--rotate) * 0.5))
                 translate(calc(var(--end-x) * 1.2), calc(var(--end-y) * 1.2));
      opacity: 1;
      animation-timing-function: ease;
    }
    85% {
      transform: rotate(calc(var(--rotate) * 0.66))
                 translate(var(--end-x), var(--end-y));
      opacity: 1;
    }
    100% {
      transform: rotate(calc(var(--rotate) * 1.2))
                 translate(calc(var(--end-x) * 0.5), calc(var(--end-y) * 0.5));
      opacity: 1;
    }
  }

  @keyframes gooey-point-anim {
    0%  { transform: scale(0); opacity: 0;
          animation-timing-function: cubic-bezier(0.55, 0, 1, 0.45); }
    25% { transform: scale(calc(var(--scale) * 0.25)); }
    38% { opacity: 1; }
    65% { transform: scale(var(--scale)); opacity: 1;
          animation-timing-function: ease; }
    85% { transform: scale(var(--scale)); opacity: 1; }
    100%{ transform: scale(0); opacity: 0; }
  }
</style>

<script define:vars={{ particleCount, particleDistances, particleR, animationTime, timeVariance, colors, initialActiveIndex }}>
  const container  = document.getElementById('gooey-nav');
  const filterEl   = document.getElementById('gooey-filter');
  const sliderPill = document.getElementById('slider-pill');
  const listItems  = Array.from(container.querySelectorAll('.gooey-item'));

  let activeIndex = initialActiveIndex;

  // ── Math helpers ────────────────────────────────────────────
  const noise = (n = 1) => n / 2 - Math.random() * n;

  function getXY(distance, pointIndex, totalPoints) {
    const angle = ((360 + noise(8)) / totalPoints) * pointIndex * (Math.PI / 180);
    return [distance * Math.cos(angle), distance * Math.sin(angle)];
  }

  function createParticle(i, t, d, r) {
    const rotate = noise(r / 10);
    return {
      start: getXY(d[0], particleCount - i, particleCount),
      end:   getXY(d[1] + noise(7), particleCount - i, particleCount),
      time:  t,
      scale: 1 + noise(0.2),
      color: colors[Math.floor(Math.random() * colors.length)],
      rotate: rotate > 0 ? (rotate + r / 20) * 10 : (rotate - r / 20) * 10,
    };
  }

  // ── Particle spawner ────────────────────────────────────────
  function makeParticles(element) {
    const d = particleDistances;
    const r = particleR;
    element.style.setProperty('--time', `${animationTime * 2 + timeVariance}ms`);
    element.classList.remove('active');

    requestAnimationFrame(() => {
      for (let i = 0; i < particleCount; i++) {
        const t = animationTime * 2 + noise(timeVariance * 2);
        const p = createParticle(i, t, d, r);

        const particle = document.createElement('span');
        const point    = document.createElement('span');
        particle.classList.add('gooey-particle');
        particle.style.setProperty('--start-x', `${p.start[0]}px`);
        particle.style.setProperty('--start-y', `${p.start[1]}px`);
        particle.style.setProperty('--end-x',   `${p.end[0]}px`);
        particle.style.setProperty('--end-y',   `${p.end[1]}px`);
        particle.style.setProperty('--time',    `${p.time}ms`);
        particle.style.setProperty('--scale',   `${p.scale}`);
        particle.style.setProperty('--color',   `var(--color-${p.color}, #E8A444)`);
        particle.style.setProperty('--rotate',  `${p.rotate}deg`);
        point.classList.add('gooey-point');
        particle.appendChild(point);
        element.appendChild(particle);
        setTimeout(() => {
          try { element.removeChild(particle); } catch {}
        }, t);
      }

      requestAnimationFrame(() => element.classList.add('active'));
    });
  }

  // ── Pill position ───────────────────────────────────────────
  function updateEffectPosition(li) {
    if (!container || !filterEl) return;
    const cRect = container.getBoundingClientRect();
    const pos   = li.getBoundingClientRect();
    filterEl.style.left   = `${pos.x - cRect.x}px`;
    filterEl.style.top    = `${pos.y - cRect.y}px`;
    filterEl.style.width  = `${pos.width}px`;
    filterEl.style.height = `${pos.height}px`;
  }

  // ── Activate item ───────────────────────────────────────────
  function activateItem(index, withParticles) {
    if (index < 0 || index >= listItems.length) return;
    if (index === activeIndex) return;

    listItems.forEach((li, i) => li.classList.toggle('active', i === index));
    activeIndex = index;

    const activeLi = listItems[index];
    updateEffectPosition(activeLi);
    // Snap slider pill to clicked item so it aligns with the gooey burst
    const cRect = container.getBoundingClientRect();
    const r = activeLi.getBoundingClientRect();
    setPill(r.left - cRect.left, r.width);

    if (withParticles) {
      // Hide pill so the dark gooey burst isn't inverted to white by difference blend
      sliderPill.style.opacity = '0';
      setTimeout(() => { sliderPill.style.opacity = ''; }, 490);
      filterEl.querySelectorAll('.gooey-particle').forEach(p => {
        try { filterEl.removeChild(p); } catch {}
      });
      makeParticles(filterEl);
    } else {
      filterEl.classList.add('active');
    }
  }

  // ── Click handlers ──────────────────────────────────────────
  // isClickScrolling: true while a click-triggered smooth scroll is in flight.
  // Scrollspy is suppressed for the duration so the pill stays at the clicked item.
  // Cleared by scrollend (exact) or a 1500ms safety fallback (no-scroll edge case).
  let isClickScrolling = false;
  let clickScrollTimeout;

  listItems.forEach((li, i) => {
    const href = li.querySelector('a')?.getAttribute('href') ?? '';
    const isPageLink = !href.includes('#');
    li.addEventListener('click', () => {
      if (!isPageLink && li.dataset.section) {
        isClickScrolling = true;
        clearTimeout(clickScrollTimeout);
        clickScrollTimeout = setTimeout(() => { isClickScrolling = false; }, 1500);
      }
      activateItem(i, !isPageLink);
    });
  });

  window.addEventListener('scrollend', () => {
    isClickScrolling = false;
    clearTimeout(clickScrollTimeout);
  }, { passive: true });

  // ── Scrollspy + real-time pill scrubber ─────────────────────
  // pageSections: built in init rAF (IIFE runs before sections are in DOM)
  // navItemRects: { left, width } per pageSections entry, relative to container
  let pageSections = [];
  let navItemRects = [];

  function buildNavItemRects() {
    const cRect = container.getBoundingClientRect();
    navItemRects = pageSections.map(s => {
      const r = listItems[s.index].getBoundingClientRect();
      return { left: r.left - cRect.left, width: r.width };
    });
  }

  function interpolateColor(t) {
    return `rgb(${Math.round(107 + 148 * t)},${Math.round(114 + 141 * t)},${Math.round(128 + 127 * t)})`;
  }

  function smoothstep(a, b, x) {
    const t = Math.max(0, Math.min(1, (x - a) / (b - a)));
    return t * t * (3 - 2 * t);
  }

  function updateTextColors(pillLeft, pillWidth) {
    const pillCenter = pillLeft + pillWidth / 2;
    const ZONE = 10; // px — half-width of crossover zone

    if (navItemRects.length === 0) {
      listItems.forEach((li, i) => {
        li.querySelector('a').style.color = interpolateColor(i === activeIndex ? 1 : 0);
      });
      return;
    }

    // If the active item is not a section (e.g. Photography), all section items
    // should stay inactive gray — the pill is outside the section range entirely.
    const activeIsNonSection =
      pageSections.length > 0 &&
      pageSections.findIndex(s => s.index === activeIndex) === -1;

    listItems.forEach((li, i) => {
      const sectIdx = pageSections.findIndex(s => s.index === i);
      if (sectIdx < 0) {
        li.querySelector('a').style.color = interpolateColor(i === activeIndex ? 1 : 0);
        return;
      }

      if (activeIsNonSection) {
        li.querySelector('a').style.color = interpolateColor(0);
        return;
      }

      const rect       = navItemRects[sectIdx];
      const itemCenter = rect.left + rect.width / 2;
      const prevCenter = sectIdx > 0
        ? navItemRects[sectIdx - 1].left + navItemRects[sectIdx - 1].width / 2
        : itemCenter - 9999;
      const nextCenter = sectIdx < navItemRects.length - 1
        ? navItemRects[sectIdx + 1].left + navItemRects[sectIdx + 1].width / 2
        : itemCenter + 9999;

      const leftBound  = (prevCenter + itemCenter) / 2;
      const rightBound = (itemCenter + nextCenter) / 2;

      const fromLeft = sectIdx === 0 ? 1 : smoothstep(leftBound - ZONE, leftBound + ZONE, pillCenter);
      const toRight  = sectIdx === navItemRects.length - 1 ? 1 : 1 - smoothstep(rightBound - ZONE, rightBound + ZONE, pillCenter);

      li.querySelector('a').style.color = interpolateColor(fromLeft * toRight);
    });
  }

  function setPill(pillLeft, pillWidth) {
    sliderPill.style.transform = `translateX(${pillLeft}px)`;
    sliderPill.style.width = `${pillWidth}px`;
    updateTextColors(pillLeft, pillWidth);
  }

  function scrubPill() {
    if (pageSections.length === 0 || navItemRects.length === 0) return;

    const threshold = window.innerHeight * 0.18;

    // Find current section (last entry whose top is above the threshold line)
    let cIdx = 0;
    for (let i = 0; i < pageSections.length; i++) {
      if (pageSections[i].el.getBoundingClientRect().top < threshold) cIdx = i;
    }
    const navIdx = pageSections[cIdx].index;

    // Suppress scrollspy while a click-triggered scroll is in flight.
    if (isClickScrolling) return;

    // Lerp pill toward next section — band scales with viewport so it's
    // proportional regardless of section height (fixes early trigger on tall sections)
    const band = window.innerHeight * 0.4;
    const nIdx = cIdx + 1;
    let pillLeft  = navItemRects[cIdx].left;
    let pillWidth = navItemRects[cIdx].width;

    if (nIdx < pageSections.length) {
      const nextTop   = pageSections[nIdx].el.getBoundingClientRect().top;
      const bandStart = threshold + band;
      if (nextTop < bandStart) {
        const t = Math.max(0, Math.min(1, (bandStart - nextTop) / band));
        pillLeft  = navItemRects[cIdx].left  + (navItemRects[nIdx].left  - navItemRects[cIdx].left)  * t;
        pillWidth = navItemRects[cIdx].width + (navItemRects[nIdx].width - navItemRects[cIdx].width) * t;
      }
    }

    setPill(pillLeft, pillWidth);

    if (navIdx !== activeIndex) {
      listItems.forEach((li, i) => li.classList.toggle('active', i === navIdx));
      activeIndex = navIdx;
    }
  }

  let scrollRaf = 0;
  window.addEventListener('scroll', () => {
    if (document.body.classList.contains('show-photography')) return;
    if (scrollRaf) cancelAnimationFrame(scrollRaf);
    scrollRaf = requestAnimationFrame(scrubPill);
  }, { passive: true });

  // ── Resize: rebuild rects and reposition pill ───────────────
  const ro = new ResizeObserver(() => {
    if (pageSections.length === 0) {
      if (listItems[activeIndex]) updateEffectPosition(listItems[activeIndex]);
      return;
    }
    buildNavItemRects();
    const cRect  = container.getBoundingClientRect();
    const r      = listItems[pageSections[0].index].getBoundingClientRect();
    const topPx  = r.top - cRect.top;
    filterEl.style.top      = `${topPx}px`;
    filterEl.style.height   = `${r.height}px`;
    sliderPill.style.top    = `${topPx}px`;
    sliderPill.style.height = `${r.height}px`;
    scrubPill();
  });
  ro.observe(container);

  // ── Init ────────────────────────────────────────────────────
  // Two rAF ticks: nav has painted, all section elements are in the DOM.
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      pageSections = listItems
        .map((li, i) => ({
          index: i,
          el: li.dataset.section ? document.getElementById(li.dataset.section) : null,
        }))
        .filter(s => s.el);

      if (pageSections.length === 0) {
        // Non-section pages (e.g. standalone photography page)
        const path = window.location.pathname;
        const pageIdx = listItems.findIndex(li => {
          const href = li.querySelector('a')?.getAttribute('href') ?? '';
          return !href.includes('#') && href.length > 1 && path.includes(
            href.replace(/^\/portfolio/, '').replace(/\/$/, '')
          );
        });
        activateItem(pageIdx >= 0 ? pageIdx : initialActiveIndex, false);
      } else {
        buildNavItemRects();
        // Set top/height (all items share the same row; any item works as reference)
        const cRect  = container.getBoundingClientRect();
        const r      = listItems[pageSections[0].index].getBoundingClientRect();
        const topPx  = r.top - cRect.top;
        filterEl.style.top      = `${topPx}px`;
        filterEl.style.height   = `${r.height}px`;
        sliderPill.style.top    = `${topPx}px`;
        sliderPill.style.height = `${r.height}px`;
        // scrubPill sets left/width and correct li.active for current scroll position
        scrubPill();
        filterEl.classList.add('active');
      }
    });
  });
</script>
