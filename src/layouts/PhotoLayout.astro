---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'The Darkroom | Kritesh Singh' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
  <title>{title}</title>

  <style>html, body, * { cursor: none !important; }</style>

  <link rel="preload" href={`${base}/fonts/space-grotesk.woff2`} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={`${base}/fonts/inter-300.woff2`}     as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={`${base}/fonts/inter-400.woff2`}     as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={`${base}/fonts/inter-500.woff2`}     as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={`${base}/fonts/inter-600.woff2`}     as="font" type="font/woff2" crossorigin />

  <link rel="icon" type="image/x-icon" href={`${base}/images/favicon.ico`} />

  <link rel="stylesheet" href={`${base}/photography/assets/css/main.css`} />
</head>
<body class="is-preload">
  <div id="cursor-glass" aria-hidden="true"></div>
  <slot />

  <script is:inline>
    (function () {
      var el = document.getElementById('cursor-glass');
      if (!el || window.matchMedia('(pointer: coarse)').matches) return;

      var cx = -9999, cy = -9999;
      var scale = 1, targetScale = 1;

      document.addEventListener('mousemove', function (e) {
        cx = e.clientX;
        cy = e.clientY;
        var t = e.target && e.target.closest && e.target.closest('a, button, [role="button"], input, select, textarea, label');
        targetScale = t ? 1.5 : 1;
      }, { passive: true });

      document.addEventListener('mouseleave', function () { el.style.opacity = '0'; });
      document.addEventListener('mouseenter', function () { el.style.opacity = '1'; });

      (function loop() {
        scale += (targetScale - scale) * 0.18;
        el.style.transform = 'translate(calc(' + cx + 'px - 50%), calc(' + cy + 'px - 50%)) scale(' + scale.toFixed(3) + ')';
        requestAnimationFrame(loop);
      }());
    }());
  </script>
</body>
</html>
