---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kritesh Singh | Product Manager',
  description = 'Kritesh Singh — Product Manager with 4 years of experience building AI-driven, customer-centric solutions. Master of Engineering Management at Dartmouth.',
} = Astro.props;

const siteUrl = 'https://singhkritesh.github.io';
const ogImage = `${siteUrl}/portfolio/images/og-image.png`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>

  <!-- Cursor: none applied inline so it takes effect before any stylesheet loads,
       eliminating the flash of native cursor on page reload. -->
  <style>html, body, * { cursor: none !important; }</style>

  <!-- Font preloads — must come before any stylesheet so fonts are in-flight
       before the browser parses CSS. With swap, they'll be ready at first paint. -->
  <link rel="preload" href={`${base}/fonts/space-grotesk.woff2`} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={`${base}/fonts/inter-300.woff2`}     as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={`${base}/fonts/inter-400.woff2`}     as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={`${base}/fonts/inter-500.woff2`}     as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={`${base}/fonts/inter-600.woff2`}     as="font" type="font/woff2" crossorigin />
  <!-- Newsreader serif — used by the intro loading screen -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap" rel="stylesheet" />

  <meta name="description" content={description} />
  <link rel="icon" type="image/x-icon" href={`${base}/images/favicon.ico`} />

  <!-- OpenGraph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={siteUrl} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Font Awesome — loaded async so it never blocks first paint or scroll restoration.
       FA only affects Contact section icons at the bottom; safe to load after render. -->
  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        media="print" onload="this.media='all'" />
  <noscript>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  </noscript>

  <!-- Hide page before first paint if we have a saved section to restore.
       Prevents the flash of home before the scroll position is applied.
       Safety timeout re-shows the page after 300ms in case something goes wrong. -->
  <script is:inline>
    (function () {
      // Take ownership of scroll restoration so the browser never auto-scrolls
      // to Y=0 (or a cached position) after our body-end inline script runs.
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      // Suppress CSS transitions during initial page load so they don't
      // fire when visibility flushes from hidden → visible on page restore.
      document.documentElement.classList.add('preload');
      var id = sessionStorage.getItem('_sk');
      if (id && id !== 'home') {
        document.documentElement.style.visibility = 'hidden';
        setTimeout(function () { document.documentElement.style.visibility = ''; }, 300);
      }
    })();
  </script>

</head>
<body class="bg-background text-[#1a1a1a] antialiased">
  <!-- Grain overlay — fixed, pointer-events off, above everything except modals -->
  <div class="grain-overlay" aria-hidden="true"></div>
  <!-- X-ray cursor — mix-blend-mode:difference inverts colors beneath it -->
  <div id="cursor-glass" aria-hidden="true"></div>
<a href="#main-content"
     class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100]
            focus:px-4 focus:py-2 focus:bg-primary focus:text-[#131313] focus:rounded-lg
            focus:font-headline focus:text-xs focus:font-bold focus:uppercase focus:tracking-wider">
    Skip to content
  </a>
  <slot />

  <script>
    const timers = new WeakMap<Element, ReturnType<typeof setTimeout>>();

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const el = entry.target as HTMLElement;
          if (entry.isIntersecting) {
            const delay = parseInt(el.dataset.revealDelay || '0', 10);
            const t = setTimeout(() => el.classList.add('revealed'), delay);
            timers.set(el, t);
          } else {
            clearTimeout(timers.get(el));
            el.classList.remove('revealed');
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -48px 0px' }
    );

    document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
      observer.observe(el);
    });
  </script>
  <script>
    // Card tilt + spotlight — rect cached on enter so mousemove never forces layout
    if (!window.matchMedia('(pointer: coarse)').matches) {
      document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((el) => {
        const MAX = 8;
        let rect: DOMRect;

        el.addEventListener('mouseenter', () => {
          rect = el.getBoundingClientRect();
          el.style.transition = 'transform 0s';
        });

        el.addEventListener('mousemove', (e) => {
          const x = (e.clientX - rect.left) / rect.width;
          const y = (e.clientY - rect.top)  / rect.height;
          const rx = (x - 0.5) * MAX * 2;
          const ry = (y - 0.5) * MAX * 2;
          el.style.transform = `perspective(900px) rotateY(${rx}deg) rotateX(${-ry}deg)`;
          el.style.backgroundImage = `radial-gradient(circle at ${x * 100}% ${y * 100}%, rgba(232,164,68,0.06) 0%, transparent 60%)`;
        });

        el.addEventListener('mouseleave', () => {
          el.style.transition = 'transform 0.5s cubic-bezier(0.23, 1, 0.32, 1)';
          el.style.transform = '';
          el.style.backgroundImage = '';
        });
      });
    }
  </script>

  <script is:inline>
    (function () {
      var el = document.getElementById('cursor-glass');
      if (!el || window.matchMedia('(pointer: coarse)').matches) return;

      // Remove the init overlay on first mousemove — it exists only to own the
      // cursor on page load so the browser fires cursor:none before JS runs.
      var cx = -9999, cy = -9999;
      var scale = 1, targetScale = 1;

      // Single mousemove does both position + hover detection — no separate mouseover
      document.addEventListener('mousemove', function (e) {
        cx = e.clientX;
        cy = e.clientY;
        var t = e.target && e.target.closest && e.target.closest('a, button, [role="button"], [data-tilt], input, select, textarea, label');
        targetScale = t ? 1.5 : 1;
      }, { passive: true });

      document.addEventListener('mouseleave', function () { el.style.opacity = '0'; });
      document.addEventListener('mouseenter', function () { el.style.opacity = '1'; });

      // RAF loop: pure pixel math (no calc), faster lerp, dead-zone to stop unnecessary composites
      var rafId;
      function loop() {
        var diff = targetScale - scale;
        scale = Math.abs(diff) > 0.001 ? scale + diff * 0.35 : targetScale;
        el.style.transform = 'translate(' + (cx - 12) + 'px,' + (cy - 12) + 'px) scale(' + scale.toFixed(3) + ')';
        rafId = requestAnimationFrame(loop);
      }
      rafId = requestAnimationFrame(loop);

      document.addEventListener('visibilitychange', function () {
        if (document.hidden) {
          cancelAnimationFrame(rafId);
        } else {
          rafId = requestAnimationFrame(loop);
        }
      });
    }());
  </script>

  <!-- Inline restore — runs synchronously after all sections are in the DOM,
       before the deferred module scripts run. Scrolls to saved section instantly. -->
  <script is:inline>
    (function () {
      var id = sessionStorage.getItem('_sk');
      if (!id || id === 'home') {
        document.documentElement.style.visibility = '';
      } else if (id === 'photography') {
        // Restore photography gallery view: show the section, hide others.
        // Only applies when #photography exists (index page), not the standalone page.
        var photoEl = document.getElementById('photography');
        if (photoEl) {
          document.body.classList.add('show-photography');
          // Nudge data-reveal elements — the IO may have already fired while the
          // section was display:none and won't fire again, leaving images invisible.
          document.querySelectorAll('#photography [data-reveal]').forEach(function (el) {
            el.classList.add('revealed');
          });
          // Masonry's define:vars IIFE runs synchronously during HTML parsing, before
          // this script fires. It sees display:none → sets isHidden=true → waits for
          // photography:show. Dispatch it now so revealAll() actually runs on reload.
          document.dispatchEvent(new CustomEvent('photography:show'));
        }
        window.scrollTo(0, 0);
        document.documentElement.style.visibility = '';
      } else {
        var el = document.getElementById(id);
        if (el) {
          // Projects uses a sticky scroll-driven panel that only activates
          // when the section top reaches viewport top — restore with no offset.
          // All other sections need 80px clearance for the fixed nav.
          var navOffset = id === 'projects' ? 0 : 80;
          window.scrollTo(0, Math.max(0, el.offsetTop - navOffset));
        }
        document.documentElement.style.visibility = '';
      }
      // Remove the preload class after two animation frames so transitions
      // are available for user interactions but didn't fire during page restore.
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          document.documentElement.classList.remove('preload');
        });
      });
    })();
  </script>
</body>
</html>
